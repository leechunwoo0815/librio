/* frontend/components/error-view/error-view.wxss */
.error-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  min-height: 400rpx;
}
.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--fg);
  margin-bottom: 12rpx;
  text-align: center;
}
.error-desc {
  font-size: 26rpx;
  color: var(--muted);
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.5;
}
.error-btn {
  background: var(--accent);
  color: var(--surface);
  border: none;
  border-radius: var(--radius);
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}
.error-btn-outline {
  background: transparent;
  color: var(--accent);
  border: 2rpx solid var(--accent);
  border-radius: var(--radius);
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}
