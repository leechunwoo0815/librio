.tab-filter {
  display: flex;
  padding: 0 16rpx;
  border-bottom: 1rpx solid var(--border);
  background: var(--surface);
}
.tab-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--muted);
  position: relative;
}
.tab-item.active {
  color: var(--fg);
  font-weight: 500;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--success);
  border-radius: 2rpx;
}
