.skeleton {
  padding: 24rpx;
}
.skeleton-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--bg);
  margin-right: 20rpx;
  flex-shrink: 0;
}
.skeleton-lines {
  flex: 1;
}
.skeleton-line {
  height: 24rpx;
  background: var(--bg);
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}
