.pay-btn {
  background: var(--accent);
  color: var(--surface);
  border: none;
  border-radius: 24px;
  padding: 14px 32px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.pay-btn.disabled { opacity: 0.5; }
.pay-amount { font-size: 18px; }
.ios-notice {
  background: var(--warning-soft);
  border: 1px solid var(--warning);
  border-radius: 12px;
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.ios-icon { font-size: 20px; }
.ios-text { font-size: 13px; color: var(--warning); line-height: 1.5; }
