.pay-btn {
  background: var(--accent);
  color: var(--surface);
  border: none;
  border-radius: 24px;
  padding: 14px 32px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.pay-btn.disabled { opacity: 0.5; }
.pay-amount { font-size: 18px; }
.pay-ios-tip { padding: 28rpx 24rpx; background: var(--warning-soft); border-radius: var(--radius); font-size: 24rpx; color: var(--warning); text-align: center; line-height: 1.5; }
