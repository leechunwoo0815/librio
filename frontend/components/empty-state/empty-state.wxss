.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  min-height: 300rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 30rpx; color: var(--muted); margin-bottom: 12rpx; text-align: center; }
.empty-desc { font-size: 24rpx; color: var(--muted); text-align: center; margin-bottom: 24rpx; }
.empty-btn { background: var(--accent); color: var(--surface); border: none; border-radius: 16rpx; padding: 16rpx 40rpx; font-size: 28rpx; }
