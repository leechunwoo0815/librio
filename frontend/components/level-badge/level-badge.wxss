.level-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #FFD700, #FFA000);
  border-radius: 20rpx;
}
.level-badge--small {
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
}
.level-badge--large {
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
}
.badge-level {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--surface);
}
.level-badge--large .badge-level {
  font-size: 28rpx;
}
.badge-name {
  font-size: 20rpx;
  color: var(--surface);
  margin-left: 8rpx;
}
