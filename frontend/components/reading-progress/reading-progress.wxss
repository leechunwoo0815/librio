.reading-progress {
  display: flex;
  align-items: center;
}
.progress-bar {
  flex: 1;
  height: 12rpx;
  background: var(--border);
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}
.progress-label {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: var(--muted);
  min-width: 60rpx;
  text-align: right;
}
