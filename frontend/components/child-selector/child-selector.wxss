.child-selector {
  display: flex;
  padding: 16rpx 0;
  overflow-x: auto;
  white-space: nowrap;
}
.child-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.child-item.active {
  border-color: var(--success);
  background: var(--success-soft);
}
.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
  background: var(--bg);
}
.child-name {
  font-size: 24rpx;
  color: var(--fg);
}
