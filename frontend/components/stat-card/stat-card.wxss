.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: var(--surface);
  border-radius: 12rpx;
}
.stat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--fg);
}
.stat-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--muted);
}
.stat-title {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
}
