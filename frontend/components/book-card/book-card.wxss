.book-card {
  display: flex;
  padding: 16rpx;
  background: var(--surface);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.book-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background: var(--bg);
}
.book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.book-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--fg);
}
.book-author {
  font-size: 24rpx;
  color: var(--muted);
}
.book-ar {
  font-size: 22rpx;
  color: var(--muted);
}
