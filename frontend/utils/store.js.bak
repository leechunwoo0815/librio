// utils/store.js — 极简响应式状态管理
//
// 架构意图：
//   当前 app.globalData 缺乏响应式能力，各页面需要手动同步数据。
//   Store 提供发布-订阅模式，数据变更时自动通知订阅者。
//   不引入 MobX 等重量级库，保持小程序轻量。

class Store {
  constructor() {
    this._state = {}
    this._listeners = {}
  }

  get(key) {
    return this._state[key]
  }

  set(key, value) {
    const old = this._state[key]
    this._state[key] = value
    if (old !== value) {
      this._notify(key, value, old)
    }
  }

  subscribe(key, listener) {
    if (!this._listeners[key]) this._listeners[key] = []
    this._listeners[key].push(listener)
    // 返回取消订阅函数
    return () => {
      this._listeners[key] = this._listeners[key].filter(l => l !== listener)
    }
  }

  _notify(key, value, old) {
    ;(this._listeners[key] || []).forEach(l => {
      try { l(value, old) } catch (e) { console.error('Store listener error:', e) }
    })
  }
}

// 全局状态键定义
const STATE_KEYS = {
  CURRENT_CHILD: 'currentChild',      // 当前选中的孩子
  CHILD_LIST: 'childList',            // 孩子列表
  USER_INFO: 'userInfo',              // 用户信息
  READING_BOOKS: 'readingBooks',      // 正在阅读列表
  UNREAD_MESSAGES: 'unreadMessages',  // 未读消息数
}

// 全局单例
const store = new Store()

module.exports = { Store, STATE_KEYS, store }
