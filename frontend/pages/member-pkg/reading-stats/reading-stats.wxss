/* frontend/pages/reading-stats/reading-stats.wxss */

/* Nav Bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.nav-bar .back-arrow {
  font-size: 36rpx;
}

.nav-bar .title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
}

/* Period Tabs */
.period-tabs {
  display: flex;
  margin: 24rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.period-btn {
  flex: 1;
  padding: 18rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--muted);
  text-align: center;
}

.period-btn.active {
  background: var(--accent);
  color: var(--surface);
}

/* Level Card */
.level-card {
  margin: 24rpx 32rpx;
  padding: 32rpx;
  border-radius: var(--radius);
  background: linear-gradient(135deg, rgba(85, 96, 207, 0.12), rgba(57, 195, 75, 0.08));
  border: 2rpx solid rgba(85, 96, 207, 0.15);
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.level-badge {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.level-badge .level-badge-emoji {
  font-size: 52rpx;
}

.level-info {
  flex: 1;
}

.level-info .level-label {
  font-size: 22rpx;
  color: var(--muted);
  display: block;
}

.level-info .level-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.level-info .level-name {
  font-family: var(--font-display);
  font-size: 36rpx;
  font-weight: 700;
}

.level-info .level-letter {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--surface);
  font-size: 22rpx;
  font-weight: 700;
}

/* Progress Card */
.progress-card {
  margin: 0 32rpx 24rpx;
  padding: 28rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
}

.prog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.prog-header .prog-title {
  font-size: 26rpx;
  font-weight: 600;
}

.prog-header .prog-count {
  font-size: 24rpx;
  color: var(--muted);
}

.prog-bar-bg {
  width: 100%;
  height: 20rpx;
  background: var(--bg);
  border-radius: 999rpx;
  overflow: hidden;
}

.prog-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--accent), var(--secondary));
}

.prog-desc {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 12rpx;
}

.prog-desc .prog-highlight {
  color: var(--accent);
  font-weight: 600;
}

/* Achievement Row */
.achievement-row {
  margin: 0 32rpx 24rpx;
  display: flex;
  gap: 16rpx;
}

.ach-item {
  flex: 1;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx 16rpx;
  text-align: center;
}

.ach-item .ach-icon {
  font-size: 44rpx;
  display: block;
  margin-bottom: 8rpx;
}

.ach-item .ach-val {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.ach-item .ach-label {
  font-size: 20rpx;
  color: var(--muted);
  margin-top: 2rpx;
  display: block;
}

/* Leaderboard Card */
.leaderboard-card {
  margin: 0 32rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
}

.lb-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.lb-header .lb-header-icon {
  font-size: 32rpx;
}

.lb-header .lb-title {
  font-family: var(--font-display);
  font-size: 28rpx;
  font-weight: 600;
}

.lb-header .lb-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--muted);
}

.lb-my-rank {
  text-align: center;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: var(--muted);
}

.lb-my-rank .lb-my-rank-num {
  color: var(--accent);
  font-weight: 700;
}

.lb-podium {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.lb-podium-item {
  text-align: center;
  flex: 1;
  max-width: 200rpx;
}

.lb-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 8rpx;
  position: relative;
}

.lb-avatar .lb-avatar-emoji {
  font-size: 36rpx;
}

.lb-avatar.rank-1 {
  background: rgba(230, 173, 0, 0.2);
  border: 4rpx solid rgba(230, 173, 0, 0.7);
  width: 104rpx;
  height: 104rpx;
}

.lb-avatar.rank-1 .lb-avatar-emoji {
  font-size: 44rpx;
}

.lb-avatar.rank-2 {
  background: rgba(180, 180, 200, 0.3);
  border: 4rpx solid rgba(180, 180, 200, 0.7);
}

.lb-avatar.rank-3 {
  background: rgba(205, 127, 50, 0.15);
  border: 4rpx solid rgba(205, 127, 50, 0.7);
}

.lb-avatar .lb-crown {
  position: absolute;
  top: -20rpx;
  font-size: 28rpx;
}

.lb-name {
  font-size: 24rpx;
  font-weight: 500;
  display: block;
}

.lb-score {
  font-size: 22rpx;
  color: var(--muted);
  display: block;
}

.lb-medal {
  font-size: 28rpx;
  margin-top: 4rpx;
  display: block;
}

/* Leaderboard List */
.lb-list {
  border-top: 2rpx solid var(--border);
  padding-top: 8rpx;
}

.lb-list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border);
  font-size: 26rpx;
}

.lb-list-item:last-child {
  border-bottom: none;
}

.lb-list-item .lb-rank {
  width: 40rpx;
  text-align: center;
  font-weight: 600;
  color: var(--muted);
  font-size: 24rpx;
}

.lb-list-item .lb-av {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(85, 96, 207, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.lb-list-item .lb-av .lb-av-emoji {
  font-size: 26rpx;
}

.lb-list-item .lb-user-name {
  flex: 1;
  font-weight: 500;
}

.lb-list-item .lb-user-score {
  color: var(--accent);
  font-weight: 600;
  font-size: 26rpx;
}

.lb-list-item.lb-me {
  background: rgba(85, 96, 207, 0.04);
  border-radius: var(--radius-sm);
  padding-left: 16rpx;
  padding-right: 16rpx;
  margin: 0 -16rpx;
}

.lb-more {
  text-align: center;
  margin-top: 16rpx;
}

.lb-more .lb-more-text {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 500;
}

/* Today Stats Grid */
.today-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 0 32rpx 32rpx;
}

.t-stat {
  width: calc(50% - 8rpx);
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 28rpx;
  text-align: center;
}

.t-stat .ts-val {
  font-family: var(--font-display);
  font-size: 48rpx;
  font-weight: 700;
  display: block;
}

.t-stat .ts-accent {
  color: var(--accent);
}

.t-stat .ts-success {
  color: var(--success);
}

.t-stat .ts-warning {
  color: var(--warning);
}

.t-stat .ts-secondary {
  color: var(--accent);
}

.t-stat .ts-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
  display: block;
}

/* Chart Card */
.chart-card {
  margin: 0 32rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
}

.chart-card .chart-title {
  font-family: var(--font-display);
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

/* Bar Chart */
.bar-chart-wrap {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  height: 280rpx;
  padding-top: 24rpx;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  height: 100%;
  justify-content: flex-end;
}

.bar-fill {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
}

.bar-fill.word-bar {
  border-radius: 8rpx 8rpx 0 0;
}

.bar-label {
  font-size: 20rpx;
  color: var(--muted);
}

/* Legend */
.legend {
  display: flex;
  gap: 32rpx;
  justify-content: center;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

/* Books Read Shelf */
.books-read {
  display: flex;
  gap: 16rpx;
  white-space: nowrap;
}

.br-item {
  flex-shrink: 0;
  width: 144rpx;
  text-align: center;
}

.br-item .br-cover {
  width: 144rpx;
  height: 192rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.br-item .br-cover .br-cover-emoji {
  font-size: 56rpx;
}

.br-item .br-name {
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--muted);
  white-space: normal;
  display: block;
}

/* Bottom nav (reading-stats specific) */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  padding: 16rpx 16rpx 40rpx;
  background: var(--surface);
  border-top: 2rpx solid var(--border);
  z-index: 10;
  box-sizing: border-box;
}
.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: var(--muted);
  padding: 8rpx 24rpx;
}
.nav-item.active {
  color: var(--accent);
}

/* 折线图 */
.line-chart {
  width: 100%;
  height: 280rpx;
}

/* 已读书架 - 滚动溢出 */
.books-read {
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 16rpx;
}
.books-read::-webkit-scrollbar {
  display: none;
}

/* 折线图 */
.line-chart {
  width: 100%;
  height: 280rpx;
}

/* 已读书架 - 滚动溢出 */
.books-read {
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 16rpx;
}
.books-read::-webkit-scrollbar {
  display: none;
}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-bar .back svg { width: 20px; height: 20px; }
.period-tabs button { flex: 1; padding: 9px; font-size: 13px; font-weight: 500; color: var(--muted); }
.period-tabs button.active { background: var(--accent); color: white; }
.t-stat.full { grid-column: 1 / -1; }
.chart-card h3 { font-family: var(--font-display); font-size: 14px; font-weight: 600; margin-bottom: 12px; }
.legend span { display: flex; align-items: center; gap: 4px; }
.books-read .br-item { flex-shrink: 0; width: 72px; text-align: center; }
.nav-item svg { width: 22px; height: 22px; }
.progress-card .prog-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.progress-card .prog-header span:first-child { font-size: 13px; font-weight: 600; }
.progress-card .prog-header span:last-child { font-size: 12px; color: var(--muted); }
.prog-desc strong { color: var(--accent); font-weight: 600; }
.leaderboard-card h3 { font-family: var(--font-display); font-size: 14px; font-weight: 600; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
.lb-crown { position: absolute; top: -10px; font-size: 14px; }
.lb-list li { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
.lb-list li:last-child { border-bottom: none; }
.lb-list .lb-rank { width: 20px; text-align: center; font-weight: 600; color: var(--muted); font-size: 12px; }
.lb-list .lb-av { width: 28px; height: 28px; border-radius: 50%; background: var(--accent-soft); display: grid; place-items: center; font-size: 13px; }
.lb-list .lb-user-name { flex: 1; font-weight: 500; }
.lb-list .lb-user-score { color: var(--accent); font-weight: 600; font-size: 13px; }
.lb-list .lb-me { background: var(--muted); border-radius: var(--radius-sm); padding-left: 8px; padding-right: 8px; margin: 0 -8px; }
