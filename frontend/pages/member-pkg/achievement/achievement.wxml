<!-- frontend/pages/member-pkg/achievement/achievement.wxml -->
<view class="page-bg">
  <view style="display:none" class="active back badge-lock locked nav-bar title top1 top2 top3"></view>

  <error-view wx:if="{{loadError}}" visible="{{loadError}}" icon="😵" title="加载失败" desc="数据加载出错了，请稍后重试" showRetry="{{true}}" retryText="重试" bind:onRetry="onRetry" />
  <loading-skeleton wx:elif="{{loading}}" />
  <block wx:if="{{!loadError && !loading}}">

  <!-- 顶部：当前级别卡片 -->
  <view class="level-card" wx:if="{{currentLevel}}">
    <view class="level-emoji">{{currentLevel.badge_emoji || '⭐'}}</view>
    <view class="level-name">{{currentLevel.level_name || 'Level 3 · 故事探索者'}}</view>
    <view class="level-desc">已读 {{currentLevel.books_read || 0}} 本 · 通过 {{currentLevel.quizzes_passed || 0}} 次测验</view>
    <view class="level-stats">
      <view class="level-stat">
        <text class="num">{{currentLevel.books_read || 0}}</text>
        <text class="label">已读书籍</text>
      </view>
      <view class="level-stat">
        <text class="num">{{currentLevel.quizzes_passed || 0}}</text>
        <text class="label">测验通过</text>
      </view>
      <view class="level-stat">
        <text class="num">{{currentLevel.streak_days || 0}}</text>
        <text class="label">连续打卡</text>
      </view>
    </view>
    <view class="level-progress" wx:if="{{advancement}}">
      <view class="level-progress-bar">
        <view class="level-progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
      <view class="level-progress-text">再读 {{advancement.books_required - advancement.books_read}} 本即可晋级 Level {{currentLevel.level_number + 1 || 4}}</view>
    </view>
    <view class="promote-btn" wx:if="{{advancement && advancement.can_advance}}" bindtap="onPromote">🎯 去晋级</view>
  </view>

  <!-- 标签页 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'badges' ? 'active' : ''}}" data-tab="badges" bindtap="onSwitchTab">徽章</view>
    <view class="tab {{activeTab === 'leaderboard' ? 'active' : ''}}" data-tab="leaderboard" bindtap="onSwitchTab">排行榜</view>
  </view>

  <!-- 徽章网格 -->
  <view class="badges-grid" wx:if="{{activeTab === 'badges'}}">
    <view
      class="badge-card {{item.earned ? '' : 'locked'}}"
      wx:for="{{achievements}}" wx:key="id"
      data-id="{{item.id}}"
      bindtap="onBadgeTap"
    >
      <view class="badge-icon" wx:if="{{item.earned}}">{{item.badge_emoji || '🏅'}}</view>
      <view class="badge-icon badge-colored-locked" wx:else>
        <text class="badge-locked-emoji">{{item.badge_emoji || '🏅'}}</text>
        <view class="badge-lock-overlay">
          <text class="lock-icon">🔒</text>
        </view>
      </view>
      <view class="badge-name">{{item.name}}</view>
      <view class="badge-date" wx:if="{{item.earned}}">{{item.dateStr}}</view>
      <view class="badge-lock-hint" wx:else>
        <text class="lock-hint-text">{{item.trigger_desc || '未获得'}}</text>
      </view>
      <!-- Near-earn progress indicator -->
      <view class="badge-progress-ring" wx:if="{{!item.earned && item.progress >= 50}}">
        <view class="badge-progress-track">
          <view class="badge-progress-fill" style="width: {{item.progress}}%"></view>
        </view>
        <text class="badge-progress-text">{{item.progress}}%</text>
      </view>
    </view>
  </view>

  <!-- 排行榜 -->
  <view class="leaderboard leaderboard-section" wx:if="{{activeTab === 'leaderboard'}}">
    <view class="lb-item" wx:for="{{leaderboardData}}" wx:key="index">
      <view class="lb-rank {{index === 0 ? 'top1' : (index === 1 ? 'top2' : (index === 2 ? 'top3' : 'normal'))}}">
        {{index + 1}}
      </view>
      <view class="lb-avatar">{{item.avatar_emoji || '👤'}}</view>
      <view class="lb-info">
        <text class="lb-name">{{item.name}}</text>
        <text class="lb-books">{{item.level_name || 'Level ' + item.level || ''}}</text>
      </view>
      <view class="lb-count">
        <text class="lb-count-num">{{item.books_read || item.total_words || 0}}</text>
        <text class="lb-count-unit"> 本</text>
      </view>
    </view>

    <!-- 当前用户排名 -->
    <view class="lb-item lb-item-me" wx:if="{{myRank > 0}}">
      <view class="lb-rank normal">{{myRank}}</view>
      <view class="lb-avatar">👦</view>
      <view class="lb-info">
        <text class="lb-name">{{myName}}（我）</text>
        <text class="lb-books">Level {{currentLevel.level_number || 3}}</text>
      </view>
      <view class="lb-count">
        <text class="lb-count-num">{{currentLevel.books_read || 0}}</text>
        <text class="lb-count-unit"> 本</text>
      </view>
    </view>
  </view>

  <!-- 最近获得时间线 -->
  <view class="timeline" wx:if="{{recentEarned.length > 0}}">
    <view class="timeline-title">最近获得</view>
    <view class="tl-item" wx:for="{{recentEarned}}" wx:key="id">
      <view class="tl-dot">{{item.badge_emoji || '🏅'}}</view>
      <view class="tl-content">
        <text class="tl-name">{{item.name}}</text>
        <text class="tl-desc">{{item.description}}</text>
        <text class="tl-time">{{item.dateStr}}</text>
      </view>
    </view>
  </view>

  <!-- 成就详情弹窗 -->
  <view class="modal-overlay {{showDetail ? 'show' : ''}}" bindtap="onCloseDetail">
    <view class="modal-card" catchtap>
      <view class="m-icon">{{selectedAchievement.badge_emoji || '🏅'}}</view>
      <view class="m-name">{{selectedAchievement.name}}</view>
      <view class="m-desc" wx:if="{{selectedAchievement.description}}">{{selectedAchievement.description}}</view>
      <view class="m-detail" wx:if="{{selectedAchievement.earned}}">
        <view class="m-detail-row">
          <text class="m-label">获得时间：</text>
          <text>{{selectedAchievement.dateStr}}</text>
        </view>
        <view class="m-detail-row" wx:if="{{selectedAchievement.trigger_desc}}">
          <text class="m-label">触发条件：</text>
          <text>{{selectedAchievement.trigger_desc}}</text>
        </view>
      </view>
      <view class="m-detail" wx:else>
        <view class="m-detail-row">
          <text class="m-label">状态：</text>
          <text>尚未获得，继续加油！</text>
        </view>
      </view>
      <view class="modal-close modal-close-btn" bindtap="onCloseDetail">确定</view>
    </view>
  </view>

  </block>
</view>
