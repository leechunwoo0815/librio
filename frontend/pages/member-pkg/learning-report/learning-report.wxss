/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-bar .back svg { width: 20px; height: 20px; }
.nav-bar .share-btn { color: var(--accent); font-size: 13px; font-weight: 500; display: flex; align-items: center; gap: 4px; }
.type-tabs button { flex: 1; padding: 9px; font-size: 13px; font-weight: 500; color: var(--muted); }
.type-tabs button.active { background: var(--accent); color: white; }
.report-card .rc-period { font-size: 12px; color: var(--muted); margin-bottom: 4px; }
.report-card .rc-title { font-family: var(--font-display); font-size: 18px; font-weight: 700; margin-bottom: 16px; }
.hl-item .hl-val { font-family: var(--font-display); font-size: 20px; font-weight: 700; }
.hl-item .hl-label { font-size: 11px; color: var(--muted); }
.suggestion .sug-icon { font-size: 18px; margin-right: 6px; }
.share-bar button { flex: 1; padding: 12px; border-radius: var(--radius-sm); font-size: 14px; font-weight: 500;
      display: flex; align-items: center; justify-content: center; gap: 6px; }
.share-bar .btn-share { background: var(--accent); color: white; }
.share-bar .btn-save { background: var(--surface); border: 1px solid var(--border); color: var(--fg); }
.nav-item { display: flex; flex-direction: column; align-items: center; gap: 2px; font-size: 10px; color: var(--muted); padding: 4px 12px; }
.nav-item.active { color: var(--accent); }
.nav-item svg { width: 22px; height: 22px; }
