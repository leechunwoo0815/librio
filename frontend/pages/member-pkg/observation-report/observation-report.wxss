/* frontend/pages/observation-report/observation-report.wxss */

/* Nav Bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}
.nav-bar .back-icon {
  font-size: 40rpx;
}
.nav-bar .title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
}

/* Report Header */
.report-header {
  margin: 32rpx 32rpx 0;
  padding: 40rpx;
  background: linear-gradient(135deg, var(--accent), var(--accent-hover));
  border-radius: var(--radius-lg);
  color: var(--surface);
  position: relative;
  overflow: hidden;
}
.rh-deco {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}
.rh-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.rh-title {
  font-family: var(--font-display);
  font-size: 36rpx;
  font-weight: 700;
}
.rh-child {
  font-size: 28rpx;
  margin-top: 8rpx;
  opacity: 0.9;
}
.rh-period {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* Section Label */
.section-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  padding: 40rpx 32rpx 20rpx;
}
.section-label-icon {
  font-size: 36rpx;
  color: var(--accent);
}

/* Stat Grid */
.stat-grid {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
}
.stat-card {
  flex: 1;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx 20rpx;
  text-align: center;
}
.sc-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.sc-icon.blue { background: var(--accent-soft); }
.sc-icon.green { background: var(--success-soft); }
.sc-icon.yellow { background: rgba(230, 173, 0, 0.12); }
.sc-icon.purple { background: rgba(85, 96, 207, 0.1); }
.sc-val {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}
.sc-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 8rpx;
}
.sc-unit {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--muted);
}

/* Level Card */
.level-card {
  margin: 0 32rpx;
  padding: 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.lc-badge {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, var(--accent), var(--accent-hover));
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--surface);
  font-family: var(--font-display);
  font-size: 48rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 32rpx var(--accent-soft);
  flex-shrink: 0;
}
.lc-info { flex: 1; }
.lc-name {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 700;
}
.lc-desc {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 4rpx;
}
.lc-progress { margin-top: 16rpx; }
.lc-progress-bar {
  height: 12rpx;
  background: var(--bg);
  border-radius: 6rpx;
  overflow: hidden;
}
.lc-progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 6rpx;
}
.lc-progress-text {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 8rpx;
}

/* Comment Card */
.comment-card {
  margin: 0 32rpx;
  padding: 32rpx;
  background: rgba(230, 173, 0, 0.12);
  border: 2rpx solid rgba(230, 173, 0, 0.25);
  border-radius: var(--radius);
}
.cc-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.cc-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(230, 173, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.cc-meta { flex: 1; }
.cc-name {
  font-family: var(--font-display);
  font-size: 26rpx;
  font-weight: 600;
}
.cc-role {
  font-size: 22rpx;
  color: var(--muted);
}
.cc-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--fg);
}
.cc-quote {
  display: inline-block;
  margin-right: 8rpx;
  color: rgba(230, 173, 0, 0.8);
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
  vertical-align: -4rpx;
}

/* Chart Card */
.chart-card {
  margin: 0 32rpx;
  padding: 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
}
.chart-title {
  font-family: var(--font-display);
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
}
.chart-bars {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  height: 220rpx;
  padding-top: 16rpx;
  border-bottom: 2rpx solid var(--border);
}
.chart-bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  height: 100%;
  justify-content: flex-end;
  position: relative;
}
.chart-bar {
  width: 100%;
  border-radius: 6rpx 6rpx 0 0;
  min-height: 6rpx;
  transition: height 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  background: linear-gradient(180deg, rgba(85,96,207,0.35), var(--accent));
  box-shadow: 0 2rpx 8rpx rgba(85,96,207,0.12);
}
.chart-bar.today {
  background: linear-gradient(180deg, rgba(57,195,75,0.3), var(--success));
  box-shadow: 0 2rpx 12rpx rgba(57,195,75,0.2);
}
.chart-bar-label {
  font-size: 20rpx;
  color: var(--muted);
}
.chart-bar-val {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--accent);
  opacity: 0;
  transition: opacity 0.3s ease;
}
.chart-bar-val.show {
  opacity: 1;
}

/* CTA Section */
.cta-section {
  margin: 40rpx 32rpx 0;
  padding: 40rpx;
  background: linear-gradient(135deg, rgba(57,195,75,0.1), rgba(85,96,207,0.1));
  border: 2rpx solid rgba(85, 96, 207, 0.12);
  border-radius: var(--radius-lg);
  text-align: center;
}
.cta-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.cta-title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}
.cta-desc {
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 32rpx;
  line-height: 1.6;
}
.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 64rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--surface);
  font-size: 30rpx;
  font-weight: 600;
}
.cta-btn:active {
  background: var(--accent-hover);
}
.cta-btn-icon {
  font-size: 32rpx;
}

/* Bottom Space */
.bottom-space { height: 40rpx; }

