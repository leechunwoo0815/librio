}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-bar .back svg { width: 20px; height: 20px; }
.nav-bar .title { font-family: var(--font-display); font-size: 17px; font-weight: 600; }
.hero h1 { font-family: var(--font-display); font-size: 22px; font-weight: 700; margin-bottom: 6px; }
.hero p { font-size: 14px; color: var(--muted); }
.price-section .duration-badge { display: inline-block; padding: 4px 14px; border-radius: 999px;
      background: var(--accent-soft); color: var(--accent); font-size: 13px; font-weight: 600; margin-bottom: 12px; }
.price-section .price-row { display: flex; align-items: baseline; justify-content: center; gap: 4px; margin-bottom: 4px; }
.price-section .price-sym { font-size: 20px; font-weight: 700; color: var(--accent); }
.price-section .price-val { font-family: var(--font-display); font-size: 48px; font-weight: 700; color: var(--accent); line-height: 1; }
.price-section .price-unit { font-size: 15px; color: var(--muted); }
.price-section .price-note { font-size: 13px; color: var(--muted); margin-top: 8px; }
.price-section .price-note svg { width: 14px; height: 14px; vertical-align: -2px; margin-right: 2px; }
.includes-card h3 { font-family: var(--font-display); font-size: 15px; font-weight: 600;
      margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }
.includes-card h3 svg { width: 18px; height: 18px; color: var(--accent); }
.includes-list li { display: flex; align-items: center; gap: 12px; padding: 10px 0;
      border-bottom: 1px solid var(--border); font-size: 14px; }
.includes-list li:last-child { border-bottom: none; }
.includes-list .inc-icon { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center;
      font-size: 18px; flex-shrink: 0; }
.includes-list .inc-icon.ic1 { background: var(--accent-soft); }
.includes-list .inc-icon.ic2 { background: var(--success-soft); }
.includes-list .inc-icon.ic3 { background: var(--secondary-soft); }
.includes-list .inc-icon.ic4 { background: var(--muted); }
.includes-list .inc-icon.ic5 { background: var(--muted); }
.includes-list .inc-title { font-weight: 600; font-size: 14px; }
.includes-list .inc-desc { font-size: 12px; color: var(--muted); margin-top: 1px; }
.guarantee-box svg { width: 20px; height: 20px; color: var(--muted); flex-shrink: 0; margin-top: 1px; }
.guarantee-box .g-text { font-size: 13px; line-height: 1.5; }
.faq-card h3 { font-family: var(--font-display); font-size: 15px; font-weight: 600;
      padding: 16px 16px 0; margin-bottom: 4px; display: flex; align-items: center; gap: 6px; }
.faq-q svg { width: 18px; height: 18px; color: var(--muted); transition: transform 0.2s; flex-shrink: 0; }
.faq-item.open .faq-q svg { transform: rotate(180deg); }
