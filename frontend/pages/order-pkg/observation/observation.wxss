/* iOS 限制提示 */
.ios-restrict {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  padding: 48rpx;
}
.ios-restrict-icon {
  font-size: 72rpx;
  margin-bottom: 32rpx;
}
.ios-restrict-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}
