<!--frontend/pages/order-pkg/official/official.wxml-->
<view class="page-bg">
  <view style="display:none" class="best dot highlight pay-bar pay-btn pay-sub title"></view>
  <view class="nav-bar">
    <navigator class="back" open-type="navigateBack" hover-class="none">‹</navigator>
    <text class="nav-title">正式会员报名</text>
  </view>

  <!-- premium hero -->
  <view class="premium-hero">
    <text class="crown">👑</text>
    <view class="premium-h1">MegaWords 正式会员</view>
    <text class="premium-p">365 天全年畅读 · A-Z 26 级进阶体系</text>
  </view>

  <!-- price -->
  <view class="price-section">
    <view class="price-badges">
      <text class="p-badge p-badge-hot">限时特惠</text>
      <text class="p-badge p-badge-annual">年度会员</text>
    </view>
    <text class="original-price" wx:if="{{!isSecondChild}}">原价 ¥6,000 / 年</text>
    <view class="price-row">
      <text class="price-sym">¥</text>
      <text class="price-val">{{actualPrice}}</text>
      <text class="price-unit">/年</text>
    </view>
    <text class="price-savings" wx:if="{{!isSecondChild}}">节省 ¥600</text>
    <view class="price-savings" wx:if="{{isSecondChild}}">第 2 孩专属 9 折</view>
    <view class="multi-child">
      <text class="mc-icon">👨‍👩‍👧‍👦</text>
      <text>第 2 孩起享 </text>
      <text class="mc-strong">¥4,860 / 年</text>
    </view>
  </view>

  <!-- benefits -->
  <view class="benefits-card">
    <view class="benefits-h3">
      <text class="benefits-h3-icon">✓</text>
      <text>正式会员权益</text>
    </view>
    <view class="benefits-list">
      <view class="benefits-item">
        <view class="ben-icon bi1">📚</view>
        <view class="ben-content">
          <text class="ben-title">全量图书在线阅读</text>
          <text class="ben-desc">3,500+ 英文原版图书，A-Z 全级别覆盖</text>
        </view>
      </view>
      <view class="benefits-item">
        <view class="ben-icon bi2">🏆</view>
        <view class="ben-content">
          <text class="ben-title">A-Z 26 级晋级体系</text>
          <text class="ben-desc">科学分级，逐级挑战，见证孩子成长</text>
        </view>
      </view>
      <view class="benefits-item">
        <view class="ben-icon bi3">📊</view>
        <view class="ben-content">
          <text class="ben-title">排行榜</text>
          <text class="ben-desc">与小伙伴一起比拼，激发阅读动力</text>
        </view>
      </view>
      <view class="benefits-item">
        <view class="ben-icon bi4">🎖️</view>
        <view class="ben-content">
          <text class="ben-title">晋级证书</text>
          <text class="ben-desc">每通过一级生成精美晋级证书</text>
        </view>
      </view>
      <view class="benefits-item">
        <view class="ben-icon bi5">⭐</view>
        <view class="ben-content">
          <text class="ben-title">成就系统</text>
          <text class="ben-desc">阅读里程碑、连续打卡、测验满分等多种成就</text>
        </view>
      </view>
    </view>
  </view>

  <!-- comparison table -->
  <view class="compare-card">
    <view class="compare-h3">权益对比</view>
    <view class="compare-table">
      <view class="compare-thead">
        <view class="compare-th compare-th-first">权益项目</view>
        <view class="compare-th">观察期</view>
        <view class="compare-th compare-th-highlight">
          <text>正式会员 </text>
          <text class="best-badge">推荐</text>
        </view>
      </view>
      <view class="compare-tr" wx:for="{{comparisons}}" wx:key="feature">
        <view class="compare-td compare-td-first">{{item.feature}}</view>
        <view class="compare-td">
          <text wx:if="{{item.observation === true}}" class="check">✓</text>
          <text wx:elif="{{item.observation === false}}" class="cross">—</text>
          <text wx:else class="compare-text">{{item.observation}}</text>
        </view>
        <view class="compare-td compare-td-highlight">
          <text wx:if="{{item.official === true}}" class="check">✓</text>
          <text wx:elif="{{item.official === false}}" class="cross">—</text>
          <text wx:else class="compare-text-bold">{{item.official}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- refund info -->
  <view class="info-card">
    <view class="info-h3">
      <text class="info-h3-icon">ℹ️</text>
      <text>退款与说明</text>
    </view>
    <view class="info-list">
      <view class="info-item">
        <view class="info-dot"></view>
        <text>按剩余时间比例退还：实付 / 365 x 剩余天数</text>
      </view>
      <view class="info-item">
        <view class="info-dot"></view>
        <text>退款将在 5 个工作日内原路返回</text>
      </view>
      <view class="info-item">
        <view class="info-dot"></view>
        <text>观察期用户升级可抵扣已支付费用</text>
      </view>
    </view>
  </view>

  <!-- pay bar -->
  <view class="fixed-bottom-bar">
    <pay-button
      amount="{{actualPrice}}"
      buttonText="{{loading ? '处理中...' : '立即开通'}}"
      disabled="{{loading}}"
      bind:pay="handleOrder"
      bind:iosfallback="showIOSNotice"
    />
  </view>
</view>
