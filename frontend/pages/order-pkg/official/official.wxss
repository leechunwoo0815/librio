/* frontend/pages/official/official.wxss — translated from design */

.page-bg {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* nav-bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  font-size: 40rpx;
  color: var(--fg);
}
.nav-title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
  color: var(--fg);
}

/* premium hero */
.premium-hero {
  margin: 32rpx;
  padding: 56rpx 40rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.15), rgba(var(--success-rgb), 0.1));
  border: 2rpx solid rgba(var(--accent-rgb), 0.2);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.crown {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}
.premium-h1 {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: var(--fg);
}
.premium-p {
  font-size: 28rpx;
  color: var(--muted);
}

/* period tabs */
.period-tabs {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 32rpx;
}
.period-tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  background: var(--surface);
}
.period-tab.active {
  border-color: var(--accent);
  background: var(--accent-soft);
}
.period-sub {
  font-size: 22rpx;
  color: var(--muted);
  display: block;
  margin-top: 4rpx;
}

/* price section */
.price-section {
  margin: 0 32rpx 24rpx;
  padding: 48rpx 40rpx;
  border-radius: var(--radius-lg);
  background: var(--surface);
  border: 2rpx solid var(--border);
  text-align: center;
}
.price-badges {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.p-badge {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.p-badge-hot {
  background: var(--error);
  color: var(--surface);
}
.p-badge-annual {
  background: var(--accent-soft);
  color: var(--accent);
}
.original-price {
  font-size: 28rpx;
  color: var(--muted);
  text-decoration: line-through;
  margin-bottom: 4rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.price-sym {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
}
.price-val {
  font-family: var(--font-display);
  font-size: 96rpx;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
}
.price-unit {
  font-size: 30rpx;
  color: var(--muted);
}
.price-savings {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
  background: var(--success-soft);
  color: var(--success);
  font-size: 26rpx;
  font-weight: 600;
}
.multi-child {
  margin-top: 20rpx;
  padding: 20rpx 32rpx;
  border-radius: var(--radius-sm);
  background: rgba(var(--warning-rgb), 0.08);
  border: 2rpx solid rgba(var(--warning-rgb), 0.15);
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: var(--muted);
}
.mc-icon {
  font-size: 32rpx;
}
.mc-strong {
  font-weight: 700;
  color: var(--warning);
}

/* benefits */
.benefits-card {
  margin: 0 32rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 36rpx 32rpx;
}
.benefits-h3 {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--fg);
}
.benefits-h3-icon {
  font-size: 36rpx;
  color: var(--accent);
}
.benefits-list {
  display: flex;
  flex-direction: column;
}
.benefits-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
}
.benefits-item:last-child {
  border-bottom: none;
}
.ben-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.bi1 { background: var(--accent-soft); }
.bi2 { background: rgba(var(--success-rgb), 0.12); }
.bi3 { background: var(--success-soft); }
.bi4 { background: rgba(var(--warning-rgb), 0.12); }
.bi5 { background: rgba(238,52,59,0.08); }
.ben-content {
  flex: 1;
}
.ben-title {
  font-weight: 600;
  font-size: 28rpx;
  color: var(--fg);
}
.ben-desc {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 2rpx;
}

/* comparison table */
.compare-card {
  margin: 0 32rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.compare-h3 {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  padding: 32rpx 32rpx 0;
  margin-bottom: 24rpx;
  text-align: center;
  color: var(--fg);
}
.compare-table {
  padding: 0 32rpx 32rpx;
}
.compare-thead {
  display: flex;
  border-bottom: 2rpx solid var(--border);
}
.compare-th {
  flex: 1;
  padding: 20rpx 24rpx;
  font-weight: 600;
  font-size: 26rpx;
  text-align: center;
  color: var(--fg);
}
.compare-th-first {
  flex: 1.5;
  text-align: left;
}
.compare-th-highlight {
  background: rgba(var(--accent-rgb), 0.06);
  border-radius: 24rpx 24rpx 0 0;
  color: var(--accent);
}
.best-badge {
  background: var(--accent);
  color: var(--surface);
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.compare-tr {
  display: flex;
  border-bottom: 2rpx solid var(--border);
}
.compare-tr:last-child {
  border-bottom: none;
}
.compare-td {
  flex: 1;
  padding: 20rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--muted);
}
.compare-td-first {
  flex: 1.5;
  text-align: left;
  justify-content: flex-start;
  font-size: 26rpx;
}
.compare-td-highlight {
  background: rgba(var(--accent-rgb), 0.03);
}
.check {
  color: var(--success);
  font-weight: 600;
}
.cross {
  color: var(--muted);
}
.compare-text {
  font-size: 26rpx;
  color: var(--muted);
}
.compare-text-bold {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--fg);
}

/* info card */
.info-card {
  margin: 0 32rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
}
.info-h3 {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--fg);
}
.info-h3-icon {
  font-size: 36rpx;
  color: var(--accent);
}
.info-list {
  display: flex;
  flex-direction: column;
}
.info-item {
  padding: 16rpx 0;
  font-size: 26rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  border-bottom: 2rpx solid var(--border);
  color: var(--muted);
}
.info-item:last-child {
  border-bottom: none;
}
.info-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  margin-top: 14rpx;
}

/* pay bar */
.pay-bar {
  position: fixed;
    box-sizing: border-box;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: var(--surface);
  border-top: 2rpx solid var(--border);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  z-index: 20;
}
.pay-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--surface);
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(var(--accent-rgb), 0.3);
}
.pay-btn:active {
  opacity: 0.92;
}
.btn-disabled {
  opacity: 0.5;
}
.pay-sub {
  text-align: center;
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 12rpx;
  display: block;
}

/* 支付按钮活跃态 */
.pay-btn:active {
  transform: scale(0.98);
}

/* 支付按钮阴影 */
.pay-btn {
  box-shadow: 0 8rpx 32rpx rgba(var(--accent-rgb), 0.3);
}

/* iOS 限制提示 */
.ios-restrict {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  padding: 48rpx;
}
.ios-restrict-icon {
  font-size: 72rpx;
  margin-bottom: 32rpx;
}
.ios-restrict-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

