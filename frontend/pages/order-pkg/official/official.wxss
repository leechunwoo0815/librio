/* frontend/pages/official/official.wxss — translated from design */

.page-bg {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* nav-bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  font-size: 40rpx;
  color: var(--fg);
}
.nav-title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
  color: var(--fg);
}

/* premium hero */
.premium-hero {
  margin: 32rpx;
  padding: 56rpx 40rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, rgba(85,96,207,0.15), rgba(57,195,75,0.1));
  border: 2rpx solid rgba(85,96,207,0.2);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.crown {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}
.premium-h1 {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: var(--fg);
}
.premium-p {
  font-size: 28rpx;
  color: var(--muted);
}

/* price section */
.price-section {
  margin: 0 32rpx 24rpx;
  padding: 48rpx 40rpx;
  border-radius: var(--radius-lg);
  background: var(--surface);
  border: 2rpx solid var(--border);
  text-align: center;
}
.price-badges {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.p-badge {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.p-badge-hot {
  background: var(--error);
  color: var(--surface);
}
.p-badge-annual {
  background: var(--accent-soft);
  color: var(--accent);
}
.original-price {
  font-size: 28rpx;
  color: var(--muted);
  text-decoration: line-through;
  margin-bottom: 4rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.price-sym {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
}
.price-val {
  font-family: var(--font-display);
  font-size: 96rpx;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
}
.price-unit {
  font-size: 30rpx;
  color: var(--muted);
}
.price-savings {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
  background: var(--success-soft);
  color: var(--success);
  font-size: 26rpx;
  font-weight: 600;
}
.multi-child {
  margin-top: 20rpx;
  padding: 20rpx 32rpx;
  border-radius: var(--radius-sm);
  background: rgba(230,173,0,0.08);
  border: 2rpx solid rgba(230,173,0,0.15);
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: var(--muted);
}
.mc-icon {
  font-size: 32rpx;
}
.mc-strong {
  font-weight: 700;
  color: var(--warning);
}

/* benefits */
.benefits-card {
  margin: 0 32rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 36rpx 32rpx;
}
.benefits-h3 {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--fg);
}
.benefits-h3-icon {
  font-size: 36rpx;
  color: var(--accent);
}
.benefits-list {
  display: flex;
  flex-direction: column;
}
.benefits-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
}
.benefits-item:last-child {
  border-bottom: none;
}
.ben-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.bi1 { background: var(--accent-soft); }
.bi2 { background: rgba(57,195,75,0.12); }
.bi3 { background: var(--success-soft); }
.bi4 { background: rgba(230,173,0,0.12); }
.bi5 { background: rgba(238,52,59,0.08); }
.ben-content {
  flex: 1;
}
.ben-title {
  font-weight: 600;
  font-size: 28rpx;
  color: var(--fg);
}
.ben-desc {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 2rpx;
}

/* comparison table */
.compare-card {
  margin: 0 32rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.compare-h3 {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  padding: 32rpx 32rpx 0;
  margin-bottom: 24rpx;
  text-align: center;
  color: var(--fg);
}
.compare-table {
  padding: 0 32rpx 32rpx;
}
.compare-thead {
  display: flex;
  border-bottom: 2rpx solid var(--border);
}
.compare-th {
  flex: 1;
  padding: 20rpx 24rpx;
  font-weight: 600;
  font-size: 26rpx;
  text-align: center;
  color: var(--fg);
}
.compare-th-first {
  flex: 1.5;
  text-align: left;
}
.compare-th-highlight {
  background: rgba(85,96,207,0.06);
  border-radius: 24rpx 24rpx 0 0;
  color: var(--accent);
}
.best-badge {
  background: var(--accent);
  color: var(--surface);
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.compare-tr {
  display: flex;
  border-bottom: 2rpx solid var(--border);
}
.compare-tr:last-child {
  border-bottom: none;
}
.compare-td {
  flex: 1;
  padding: 20rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--muted);
}
.compare-td-first {
  flex: 1.5;
  text-align: left;
  justify-content: flex-start;
  font-size: 26rpx;
}
.compare-td-highlight {
  background: rgba(85,96,207,0.03);
}
.check {
  color: var(--success);
  font-weight: 600;
}
.cross {
  color: var(--muted);
}
.compare-text {
  font-size: 26rpx;
  color: var(--muted);
}
.compare-text-bold {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--fg);
}

/* info card */
.info-card {
  margin: 0 32rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
}
.info-h3 {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--fg);
}
.info-h3-icon {
  font-size: 36rpx;
  color: var(--accent);
}
.info-list {
  display: flex;
  flex-direction: column;
}
.info-item {
  padding: 16rpx 0;
  font-size: 26rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  border-bottom: 2rpx solid var(--border);
  color: var(--muted);
}
.info-item:last-child {
  border-bottom: none;
}
.info-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  margin-top: 14rpx;
}

/* pay bar */
.pay-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: var(--surface);
  border-top: 2rpx solid var(--border);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  z-index: 20;
}
.pay-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--surface);
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(85,96,207,0.3);
}
.pay-btn:active {
  opacity: 0.92;
}
.btn-disabled {
  opacity: 0.5;
}
.pay-sub {
  text-align: center;
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 12rpx;
  display: block;
}

/* Premium hero 装饰圆形 */
.premium-hero::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(230, 173, 0, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

/* 支付按钮活跃态 */
.pay-btn:active {
  transform: scale(0.98);
}

/* 支付按钮阴影 */
.pay-btn {
  box-shadow: 0 8rpx 32rpx rgba(85, 96, 207, 0.3);
}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-bar .back svg { width: 20px; height: 20px; }
.nav-bar .title { font-family: var(--font-display); font-size: 17px; font-weight: 600; }
.premium-hero .crown { font-size: 48px; margin-bottom: 8px; }
.premium-hero h1 { font-family: var(--font-display); font-size: 22px; font-weight: 700; margin-bottom: 6px; }
.premium-hero p { font-size: 14px; color: var(--muted); }
.multi-child svg { width: 16px; height: 16px; color: var(--muted); }
.multi-child strong { color: var(--muted); }
.benefits-card h3 { font-family: var(--font-display); font-size: 15px; font-weight: 600;
      margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }
.benefits-card h3 svg { width: 18px; height: 18px; color: var(--accent); }
.benefits-list li { display: flex; align-items: center; gap: 12px; padding: 10px 0;
      border-bottom: 1px solid var(--border); font-size: 14px; }
.benefits-list li:last-child { border-bottom: none; }
.ben-icon.bi1 { background: var(--accent-soft); }
.ben-icon.bi2 { background: var(--secondary-soft); }
.ben-icon.bi3 { background: var(--success-soft); }
.ben-icon.bi4 { background: var(--muted); }
.ben-icon.bi5 { background: var(--muted); }
.compare-card h3 { font-family: var(--font-display); font-size: 15px; font-weight: 600;
      padding: 16px 16px 0; margin-bottom: 12px; text-align: center; }
.compare-table thead th { padding: 10px 12px; font-weight: 600; font-size: 13px; text-align: center;
      border-bottom: 1px solid var(--border); }
.compare-table thead th:first-child { text-align: left; }
.compare-table thead th.highlight { background: var(--accent-soft); color: var(--accent); border-radius: 12px 12px 0 0; }
.compare-table td { padding: 10px 12px; text-align: center; border-bottom: 1px solid var(--border); }
.compare-table td:first-child { text-align: left; color: var(--muted); font-size: 13px; }
.compare-table td.highlight { background: var(--muted); }
.compare-table tr:last-child td { border-bottom: none; }
.compare-table .check { color: var(--success); font-weight: 600; }
.compare-table .cross { color: var(--muted); }
.compare-table .best { background: var(--accent); color: white; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 999px; }
.info-card h3 { font-family: var(--font-display); font-size: 15px; font-weight: 600;
      margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }
.info-card h3 svg { width: 18px; height: 18px; color: var(--accent); }
.info-list li { padding: 8px 0; font-size: 13px; display: flex; align-items: flex-start; gap: 8px;
      border-bottom: 1px solid var(--border); }
.info-list li:last-child { border-bottom: none; }
.info-list .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent); flex-shrink: 0; margin-top: 7px; }
