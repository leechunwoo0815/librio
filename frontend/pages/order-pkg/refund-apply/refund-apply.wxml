<!-- frontend/pages/order-pkg/refund-apply/refund-apply.wxml -->
<view class="page-bg">
  <view class="nav-bar">
    <navigator class="back" open-type="navigateBack" hover-class="none">‹</navigator>
    <text class="nav-title title">退款申请</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:else>
    <view class="empty-state" wx:if="{{orders.length === 0}}">
      <view class="empty-icon">🚫</view>
      <text class="empty-text">暂无可退款的订单</text>
    </view>

    <block wx:else>
      <!-- Order Selector -->
      <view class="selector-card">
        <text class="card-label">选择订单</text>
        <picker range="{{orderNames}}" value="{{selectedOrderIndex}}" bindchange="onOrderChange">
          <view class="picker-field">
            <text>{{orderNames[selectedOrderIndex]}}</text>
            <text class="picker-arrow">▾</text>
          </view>
        </picker>
      </view>

      <!-- Order Info Card -->
      <view class="info-card" wx:if="{{selectedOrder}}">
        <text class="card-h3">订单信息</text>
        <view class="info-row">
          <text class="info-label label">订单类型</text>
          <text class="info-value value">{{selectedOrder.type === 'observation' ? '观察期' : (selectedOrder.type === 'official' ? '正式会员' : selectedOrder.type)}}</text>
        </view>
        <view class="info-row">
          <text class="info-label label">实付金额</text>
          <text class="info-value value">¥{{selectedOrder.amount}}</text>
        </view>
        <view class="info-row">
          <text class="info-label label">支付时间</text>
          <text class="info-value value">{{selectedOrder.pay_time || selectedOrder.create_time}}</text>
        </view>
        <view class="info-row total" wx:if="{{selectedOrder.expire_date}}">
          <text class="info-label label">会员有效期</text>
          <text class="info-value value">— {{selectedOrder.expire_date}}</text>
        </view>
      </view>

      <!-- Used Days -->
      <view class="days-card">
        <text class="card-label">已使用天数</text>
        <input
          class="days-input"
          type="number"
          placeholder="请输入已使用天数"
          value="{{usedDays}}"
          bindinput="onUsedDaysInput"
        />
      </view>

      <!-- Refund Calculation Card -->
      <view class="calc-card" wx:if="{{selectedOrder}}">
        <text class="card-h3">退款金额计算</text>
        <view class="calc-step">
          <view class="calc-dot dot calc-dot-n n">1</view>
          <text class="calc-desc desc">实付金额</text>
          <text class="calc-amount amount">¥{{selectedOrder.amount}}</text>
        </view>
        <view class="calc-step">
          <view class="calc-dot dot calc-dot-minus minus">−</view>
          <text class="calc-desc desc">已使用 {{usedDays}} 天（¥{{dailyRate}}/天）</text>
          <text class="calc-amount amount">¥{{usedAmount}}</text>
        </view>
        <view class="calc-result">
          <text class="calc-result-label label">应退金额</text>
          <text class="calc-result-amount amount">¥{{refundAmount}}</text>
        </view>
      </view>

      <!-- Reason Card -->
      <view class="reason-card">
        <text class="card-h3">退款原因</text>
        <textarea
          class="reason-textarea"
          placeholder="请填写退款原因，以便我们改进服务…"
          maxlength="500"
          value="{{reason}}"
          bindinput="onReasonInput"
        />
      </view>

      <!-- Tip Card -->
      <view class="tip-card">
        <text class="tip-icon">ℹ️</text>
        <text class="tip-text">退款申请提交后将在 1-3 个工作日内审核。</text>
      </view>

      <!-- Submit Button -->
      <view class="fixed-bottom-bar submit-wrap">
        <view class="fixed-bottom-btn submit-btn {{submitting ? 'btn-disabled' : ''}}" bindtap="onSubmitRefund">
          <text>{{submitting ? '提交中...' : '提交退款申请'}}</text>
        </view>
      </view>
    </block>
  </block>
</view>
