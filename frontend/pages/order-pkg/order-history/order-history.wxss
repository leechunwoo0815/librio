/* order-history.wxss — aligned with design/user-end/order-history.html */

.page-bg {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* Nav Bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 40rpx;
  color: var(--fg);
}

.nav-title,
.title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
  color: var(--fg);
}

/* Tabs */
.tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 96rpx;
  z-index: 9;
}

.tab {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--muted);
  font-weight: 500;
  position: relative;
}

.tab-active,
.tab.active {
  color: var(--accent);
}

.tab-active::after,
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: var(--accent);
  border-radius: 2rpx;
}

/* Order List */
.order-list {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Order Card */
.order-card {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.order-id {
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--muted);
}

.order-status {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-paid {
  background: var(--success-soft);
  color: var(--success);
}

.badge-pending {
  background: var(--warning-soft);
  color: var(--warning);
}

.badge-refunded {
  background: var(--error-soft);
  color: var(--error);
}

.order-body {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.order-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.order-icon-type3 {
  background: var(--accent-soft);
}

.order-icon-type2 {
  background: var(--secondary-soft);
}

.order-icon-type1 {
  background: var(--success-soft);
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.order-type {
  font-weight: 600;
  font-size: 30rpx;
  color: var(--fg);
}

.order-time {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

.order-amount {
  font-family: var(--font-display);
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent);
}

.order-amount-refund {
  text-decoration: line-through;
  color: var(--muted);
}

/* Order Footer */
.order-footer {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--border);
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn-sm {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.btn-outline {
  border: 2rpx solid var(--border);
  color: var(--muted);
}

.btn-danger {
  background: var(--error-soft);
  color: var(--error);
}

/* Status badge aliases (matching prototype class names) */
.status-paid {
  background: var(--success-soft);
  color: var(--success);
}

.status-pending {
  background: var(--warning-soft);
  color: var(--warning);
}

.status-refund {
  background: var(--error-soft);
  color: var(--error);
}

/* Order icon type aliases (matching prototype class names) */
.order-icon.course {
  background: var(--accent-soft);
}

.order-icon.observe {
  background: var(--secondary-soft);
}

.order-icon.member {
  background: var(--success-soft);
}

/* Empty state icon opacity */
.empty-state svg {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 24rpx;
  opacity: 0.4;
}

.empty-state p {
  font-size: 28rpx;
}

/* Loading / No More */
.loading-more {
  text-align: center;
  padding: 32rpx;
  color: var(--muted);
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  padding: 32rpx;
  color: var(--muted);
  font-size: 26rpx;
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: var(--muted);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--muted);
}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-bar .back svg { width: 20px; height: 20px; }
.nav-bar .title { font-family: var(--font-display); font-size: 17px; font-weight: 600; }
