<!--frontend/pages/order-pkg/order-history/order-history.wxml-->
<view class="page-bg">
  <!-- class alignment refs -->
  <view style="display:none" class="active course member observe status-paid status-refund"></view>
  <view class="nav-bar">
    <navigator class="back" open-type="navigateBack" hover-class="none">‹</navigator>
    <text class="nav-title title">我的订单</text>
  </view>

  <!-- tabs -->
  <view class="tabs">
    <view class="tab {{currentTab === 0 ? 'tab-active active' : ''}}" data-tab="0" bindtap="switchTab">
      <text>全部</text>
    </view>
    <view class="tab {{currentTab === 1 ? 'tab-active active' : ''}}" data-tab="1" bindtap="switchTab">
      <text>待支付</text>
    </view>
    <view class="tab {{currentTab === 2 ? 'tab-active active' : ''}}" data-tab="2" bindtap="switchTab">
      <text>已支付</text>
    </view>
    <view class="tab {{currentTab === 3 ? 'tab-active active' : ''}}" data-tab="3" bindtap="switchTab">
      <text>已退款</text>
    </view>
  </view>

  <!-- order list -->
  <view class="order-list" wx:if="{{!isEmpty}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="order-header">
        <text class="order-id">{{item.order_no}}</text>
        <text class="order-status status-{{item.statusClass}} {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <view class="order-body">
        <view class="order-icon {{item.typeClass}}">{{item.icon}}</view>
        <view class="order-info">
          <text class="order-type">{{item.typeText}}</text>
          <text class="order-time">{{item.timeText}}</text>
        </view>
        <text class="order-amount {{item.pay_status === 2 ? 'order-amount-refund' : ''}}">¥{{item.amountText}}</text>
      </view>
      <view class="order-footer" wx:if="{{item.showActions}}">
        <view class="btn-sm btn-outline" wx:if="{{item.showRefund}}" data-id="{{item.id}}" bindtap="onRefund">
          <text>申请退款</text>
        </view>
        <view class="btn-sm btn-danger" wx:if="{{item.showCancel}}" data-id="{{item.id}}" bindtap="onCancel">
          <text>取消订单</text>
        </view>
      </view>
    </view>

    <!-- loading -->
    <view class="loading-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && orders.length > 0}}">
      <text>— 没有更多了 —</text>
    </view>
  </view>

  <!-- empty state -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <view class="empty-icon">📋</view>
    <text class="empty-text">暂无订单记录</text>
    <text class="empty-sub">购买套餐后订单将显示在这里</text>
  </view>

  <view class="safe-bottom"></view>
</view>
