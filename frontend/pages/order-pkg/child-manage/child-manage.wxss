/* child-manage.wxss — aligned with design/user-end/child-manage.html */

.page {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* Nav Bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.nav-bar .back-icon {
  font-size: 40rpx;
  color: var(--fg);
}

.nav-bar .title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
  color: var(--fg);
}

/* Section Title */
.section-title {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  padding: 32rpx 32rpx 16rpx;
  color: var(--fg);
}

/* Child Card */
.child-card {
  margin: 0 32rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  position: relative;
}

.child-card.current {
  border-color: var(--accent);
  border-width: 4rpx;
}

.child-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.child-avatar.g1 {
  background: var(--accent-soft);
}

.child-avatar.g2 {
  background: var(--secondary-soft);
}

.child-info {
  flex: 1;
}

.child-name {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--fg);
  display: block;
}

.child-meta {
  font-size: 26rpx;
  color: var(--muted);
  margin-top: 4rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.meta-dot {
  color: var(--muted);
}

.child-level {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  display: inline-block;
  margin-top: 8rpx;
}

.level-g1 {
  background: var(--accent-soft);
  color: var(--accent);
}

.level-g2 {
  background: var(--secondary-soft);
  color: var(--success);
}

.current-tag {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: var(--accent);
  font-size: 20rpx;
  font-weight: 600;
}

.current-tag text {
  color: var(--surface);
}

.child-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.child-stat {
  font-size: 24rpx;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 24rpx;
}

.child-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.child-action-btn {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid var(--border);
  color: var(--muted);
}

/* Add Button */
.add-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  padding: 24rpx 32rpx 56rpx;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
  background: var(--surface);
  border-top: 2rpx solid var(--border);
  box-sizing: border-box;
}

.add-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: var(--radius);
  background: var(--accent);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.add-btn text {
  color: var(--surface);
}

.add-icon {
  font-size: 36rpx;
  color: var(--surface);
}

/* Loading */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--muted);
  font-size: 28rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--muted);
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-body {
  width: 100%;
  background: var(--surface);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.modal-title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
  color: var(--fg);
}

.modal-close {
  font-size: 36rpx;
  color: var(--muted);
  padding: 8rpx;
}

/* Form */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  height: 80rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--muted);
}

.submit-btn {
  margin-top: 32rpx;
  width: 100%;
  padding: 28rpx;
  border-radius: var(--radius);
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn text {
  color: var(--surface);
  font-size: 30rpx;
  font-weight: 600;
}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-bar .back svg { width: 20px; height: 20px; }
.child-card:active { border-color: var(--accent); }
.child-stat svg { width: 12px; height: 12px; }
.add-btn:active { opacity: 0.85; }
.add-btn svg { width: 18px; height: 18px; }
.child-action-btn:active { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }
