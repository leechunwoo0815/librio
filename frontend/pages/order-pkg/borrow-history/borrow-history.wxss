/* borrow-history.wxss — aligned with design/user-end/borrow-history.html */

.page-bg {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* Nav Bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 40rpx;
  color: var(--fg);
}

.nav-title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
  color: var(--fg);
}

/* Tabs */
.tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 96rpx;
  z-index: 9;
}

.tab {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--muted);
  font-weight: 500;
  position: relative;
}

.tab.active {
  color: var(--accent);
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: var(--accent);
  border-radius: 2rpx;
}

/* Summary Bar */
.summary-bar {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}

.summary-card {
  flex: 1;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  text-align: center;
}

.summary-num {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
}

.summary-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

/* Record List */
.record-list {
  padding: 0 32rpx;
}

.record-card {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 24rpx;
}

.record-cover {
  width: 112rpx;
  height: 144rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border: 2rpx solid var(--border);
  overflow: hidden;
  background: linear-gradient(135deg, #f0f2f5, #e4e8ed); /* intentional decorative */
}

.record-cover image {
  width: 100%;
  height: 100%;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: var(--fg);
}

.record-dates {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 12rpx;
  line-height: 1.7;
}

.record-tags {
  display: flex;
  gap: 12rpx;
  align-items: center;
  flex-wrap: wrap;
}

/* Status Tags */
.record-status {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.st-borrowed {
  background: var(--success-soft);
  color: var(--success);
}

.st-returned {
  background: rgba(85, 95, 105, 0.1);
  color: var(--muted);
}

.st-overdue {
  background: var(--error-soft);
  color: var(--error);
}

.st-lost {
  background: rgba(85, 95, 105, 0.15);
  color: var(--fg);
}

.record-test {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 500;
  background: var(--accent-soft);
  color: var(--accent);
}

.record-fine {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  background: var(--error-soft);
  color: var(--error);
}

/* Date Divider */
.date-divider {
  padding: 24rpx 0 12rpx;
  font-size: 24rpx;
  color: var(--muted);
  font-weight: 500;
}

/* Content Sections */
.content-section {
  display: none;
}

.content-section.active {
  display: block;
}
