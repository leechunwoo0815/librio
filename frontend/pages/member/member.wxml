<view class="page-bg">

  <error-view wx:if="{{loadError}}" visible="{{loadError}}" icon="<text class="icon icon-dizzy-face">😵</text>" title="加载失败" desc="数据加载出错了" showRetry="{{true}}" retryText="重试" bind:onRetry="onRetry" />
  <loading-skeleton wx:elif="{{loading}}" />

  <block wx:elif="{{child}}">
  <!-- Profile Header -->
  <view class="profile-header">
    <view class="profile-top">
      <view class="profile-avatar">
        <text><text class="icon icon-girl">👧</text></text>
      </view>
      <view class="profile-info">
        <text class="profile-name">{{child.name || userInfo.nickname || '用户'}} {{child.english_name || ''}}</text>
        <text class="profile-level"><text class="icon icon-seedling">🌱</text> {{child.levelName || 'A级'}}</text>
      </view>
      <view class="profile-settings"><text class="icon icon-gear">⚙</text></view>
    </view>
  </view>

  <!-- Child Switcher -->
  <view class="child-switcher" wx:if="{{children.length > 1}}">
    <view class="child-switcher-label">切换孩子</view>
    <scroll-view scroll-x class="child-switcher-scroll">
      <view
        class="child-switcher-chip {{child.id === item.id ? 'active' : ''}}"
        wx:for="{{children}}" wx:key="id"
        data-index="{{index}}"
        bindtap="switchChild"
      >
        {{item.english_name || item.name}}
      </view>
    </scroll-view>
  </view>

  <!-- Member Status Card -->
  <view class="member-card {{statusClass}}">
    <view class="mc-deco"></view>
    <view class="mc-top">
      <text class="mc-status">{{statusText || '体验用户'}}</text>
      <text class="mc-badge" wx:if="{{child.venue_name}}">{{child.venue_name}}</text>
      <text class="mc-badge" wx:elif="{{child.status === 2}}">正式会员</text>
      <text class="mc-badge" wx:elif="{{child.status === 1}}">观察期</text>
      <text class="mc-badge" wx:else>体验</text>
    </view>
    <view class="mc-countdown" wx:if="{{countdownText}}">{{countdownText}}</view>
    <view class="mc-countdown-label" wx:if="{{countdownText}}">距离到期</view>
    <view class="mc-expires" wx:if="{{expireText}}">到期时间：{{expireText}}</view>
  </view>

  <!-- Quick Stats -->
  <view class="quick-stats">
    <view class="qs-item">
      <text class="qs-val">{{child.total_reading_minutes || '0'}}</text>
      <text class="qs-label">累计阅读分钟</text>
    </view>
    <view class="qs-item">
      <text class="qs-val">{{child.total_words_read || '0'}}</text>
      <text class="qs-label">累计词</text>
    </view>
    <view class="qs-item">
      <text class="qs-val">{{child.total_books_finished || '0'}}</text>
      <text class="qs-label">本书</text>
    </view>
    <view class="qs-item">
      <text class="qs-val">{{child.current_streak_days || '0'}}</text>
      <text class="qs-label">连续打卡天</text>
    </view>
  </view>

  <!-- Tier List -->
  <view class="tier-list" wx:if="{{tiers.length > 0}}">
    <view class="section-title">会员方案</view>
    <view class="tier-grid">
      <view
        class="tier-card"
        wx:for="{{tiers}}" wx:key="type"
        data-type="{{item.type}}"
        bindtap="goTier"
      >
        <view class="tier-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
        <text class="tier-name">{{item.name}}</text>
        <text class="tier-price">¥{{item.price}}<text class="tier-unit">/{{item.unit}}</text></text>
        <view class="tier-features">
          <text class="tier-feature" wx:for="{{item.features}}" wx:key="*this">{{item}}</text>
        </view>
        <button class="tier-cta">{{item.cta || '立即开通'}}</button>
      </view>
    </view>
  </view>
  </block>

  <!-- Function Grid -->
  <view class="section-title">功能入口</view>
  <view class="func-grid">
    <navigator url="/pages/books/books" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-book">书</text></text>
      </view>
      <text class="fi-label">图书馆</text>
    </navigator>
    <navigator url="/pages/shelf/shelf" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-book-open">读</text></text>
      </view>
      <text class="fi-label">书架</text>
    </navigator>
    <navigator url="/pages/member-pkg/reading-stats/reading-stats" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-chart">📊</text></text>
      </view>
      <text class="fi-label">阅读统计</text>
    </navigator>
    <navigator url="/pages/member-pkg/achievement/achievement" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-trophy">🏆</text></text>
      </view>
      <text class="fi-label">成就中心</text>
    </navigator>
    <navigator url="/pages/member-pkg/learning-report/learning-report" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-note">📝</text></text>
      </view>
      <text class="fi-label">学习报告</text>
    </navigator>
    <navigator url="/pages/reading-pkg/vocabulary/vocabulary" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-clipboard">📋</text></text>
      </view>
      <text class="fi-label">生词本</text>
    </navigator>
    <navigator url="/pages/order-pkg/deposit/deposit" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-money">💰</text></text>
      </view>
      <text class="fi-label">押金管理</text>
    </navigator>
    <navigator url="/pages/order-pkg/borrow-history/borrow-history" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-package">📦</text></text>
      </view>
      <text class="fi-label">借阅记录</text>
    </navigator>
    <navigator url="/pages/order-pkg/reservation/reservation" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-calendar">📅</text></text>
      </view>
      <text class="fi-label">预约管理</text>
    </navigator>
    <navigator url="/pages/order-pkg/child-manage/child-manage" class="func-item">
      <view class="fi-icon">
        <text><text class="icon icon-baby">👶</text></text>
      </view>
      <text class="fi-label">孩子管理</text>
    </navigator>
  </view>

  <!-- Bottom Links -->
  <view class="bottom-links">
    <button class="link-item" open-type="contact" session-from="member-page" style="background:none;padding:0;margin:0;line-height:inherit;text-align:left;border:none;font-size:inherit">
      <view class="lk-left">
        <text class="lk-icon"><text class="icon icon-chat">💬</text></text>
        <text class="lk-text">联系客服</text>
      </view>
      <text class="lk-arrow">›</text>
    </button>
    <view class="link-item" bindtap="showAbout">
      <view class="lk-left">
        <text class="lk-icon"><text class="icon icon-info">ℹ</text></text>
        <text class="lk-text">关于我们</text>
      </view>
      <text class="lk-arrow">›</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
