/* frontend/pages/member/member.wxss */
/* Translated from design/user-end/member.html */
/* Color mapping: var(--accent) → var(--accent) (primary purple) */
/*               #7fd85a → #34d399 (secondary green)  */
/*               #3dd68c → var(--success) (success green)    */
/*               var(--warning)  → var(--warning) (warning gold)     */

/* ================================================================
   Member Status Card
   ================================================================ */
.member-card {
  margin: 32rpx;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
  color: var(--surface);
  /* default: gray gradient (trial / expired) */
  background: linear-gradient(135deg, var(--muted) 0%, #78716c 100%);
}
.member-card.official {
  background: linear-gradient(135deg, var(--accent), #4550b8);
}
.member-card.observation {
  background: linear-gradient(135deg, var(--success), #2da83e);
}

/* decorative circle — pseudo-element fallback via nested view */
.mc-deco {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.mc-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.mc-status {
  font-size: 28rpx;
  font-weight: 600;
}
.mc-badge {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 22rpx;
  font-weight: 600;
}
.mc-countdown {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}
.mc-countdown-label {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}
.mc-expires {
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 16rpx;
}

/* ================================================================
   Identity Card
   ================================================================ */
.id-card {
  margin: 0 32rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
}
.id-top {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 20rpx;
}
.id-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--accent-soft);
  border: 4rpx solid var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
}
.id-avatar-icon {
  font-size: 48rpx;
  color: var(--accent);
}
.id-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.id-name {
  font-size: 32rpx;
  font-weight: 700;
}
.id-role {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 500;
  margin-top: 4rpx;
}
.id-meta {
  display: flex;
  gap: 32rpx;
  font-size: 24rpx;
  color: var(--muted);
}
.id-meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* ================================================================
   Child Switch
   ================================================================ */
.child-switch {
  margin: 0 32rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.cs-label {
  font-size: 26rpx;
  color: var(--muted);
  flex-shrink: 0;
}
.cs-picker {
  flex: 1;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  font-size: 28rpx;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.cs-arrow {
  font-size: 20rpx;
  color: var(--muted);
  margin-left: 12rpx;
}
.cs-manage {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 500;
  flex-shrink: 0;
}

/* ================================================================
   Level Section
   ================================================================ */
.level-section {
  margin: 0 32rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.ls-emoji {
  font-size: 64rpx;
  flex-shrink: 0;
}
.ls-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.ls-name {
  font-weight: 600;
  font-size: 30rpx;
}
.ls-sub {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 4rpx;
}
.ls-bar {
  margin-top: 12rpx;
  height: 12rpx;
  background: var(--muted);
  border-radius: 6rpx;
  overflow: hidden;
}
.ls-bar-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 6rpx;
}
.ls-link {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ================================================================
   Alert / Renewal Card
   ================================================================ */
.alert-card {
  margin: 0 32rpx 24rpx;
  padding: 28rpx 32rpx;
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.alert-card.warning {
  background: var(--warning-soft);
  border: 2rpx solid rgba(230, 173, 0, 0.2);
}
.alert-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}
.alert-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--fg);
  line-height: 1.5;
}
.alert-strong {
  font-weight: 600;
}
.alert-btn {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: var(--warning);
  color: var(--surface);
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  line-height: 1.4;
}
.alert-btn::after {
  border: none;
}

/* ================================================================
   Reading Stats
   ================================================================ */
.reading-stats {
  margin: 0 32rpx 32rpx;
  display: flex;
  gap: 12rpx;
}
.rs-item {
  flex: 1;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
}
.rs-val {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}
.rs-val-purple {
  color: var(--accent);
}
.rs-val-green {
  color: var(--success);
}
.rs-val-success {
  color: var(--success);
}
.rs-val-gold {
  color: var(--warning);
}
.rs-label {
  font-size: 20rpx;
  color: var(--muted);
  margin-top: 4rpx;
  line-height: 1.3;
}

/* ================================================================
   Section Title
   ================================================================ */
.section-title {
  margin: 32rpx 32rpx 20rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* ================================================================
   Membership Tiers
   ================================================================ */
.tier-grid {
  margin: 0 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.tier-card {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
  position: relative;
  overflow: hidden;
}
.tier-card.recommended {
  border-color: rgba(85, 96, 207, 0.3);
  box-shadow: 0 0 0 2rpx var(--accent-soft);
}
.tier-tag {
  position: absolute;
  top: 0;
  right: 0;
  padding: 6rpx 20rpx;
  border-radius: 0 0 0 var(--radius-sm);
  background: var(--accent);
  color: var(--surface);
  font-size: 20rpx;
  font-weight: 600;
}
.tier-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.tier-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}
.tier-price {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
}
.tier-unit {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--muted);
  margin-left: 8rpx;
}
.tier-features {
  margin-bottom: 8rpx;
}
.tier-feature-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 4rpx 0;
  font-size: 24rpx;
  color: var(--fg);
  line-height: 1.6;
}
.tier-dot {
  color: var(--accent);
  font-weight: 700;
  font-size: 28rpx;
  line-height: 1.5;
  flex-shrink: 0;
}
.tier-feat-text {
  flex: 1;
}
.tier-btn {
  margin-top: 16rpx;
}

/* ================================================================
   Discount Note
   ================================================================ */
.discount-note {
  margin: 0 32rpx 24rpx;
  padding: 20rpx 28rpx;
  background: var(--success-soft);
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: var(--fg);
  text-align: center;
}

/* ================================================================
   Feature Grid
   ================================================================ */
.func-grid {
  margin: 0 32rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.func-item {
  width: calc(20% - 13rpx);
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx 8rpx 20rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}
.func-item:active {
  transform: scale(0.95);
}
.fi-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fi-emoji {
  font-size: 40rpx;
}
.fi-label {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--fg);
}

/* Feature icon background colors */
/* 1: accent-soft (purple)  — rgba(107,92,231,0.1) */
.fi-icon-1 {
  background: var(--accent-soft);
}
/* 2: secondary-soft (green) */
.fi-icon-2 {
  background: rgba(57, 195, 75, 0.1);
}
/* 3: success-soft */
.fi-icon-3 {
  background: rgba(57, 195, 75, 0.1);
}
/* 4: warning-soft */
.fi-icon-4 {
  background: rgba(230, 173, 0, 0.12);
}
/* 5: error-soft */
.fi-icon-5 {
  background: rgba(238, 52, 59, 0.08);
}
/* 6: accent-soft (lighter) */
.fi-icon-6 {
  background: rgba(85, 96, 207, 0.08);
}
/* 7: secondary-soft (green, stronger) */
.fi-icon-7 {
  background: rgba(57, 195, 75, 0.12);
}
/* 8: muted-soft */
.fi-icon-8 {
  background: rgba(85, 95, 105, 0.1);
}
/* 9: accent-soft */
.fi-icon-9 {
  background: rgba(85, 96, 207, 0.08);
}
/* 10: secondary-soft (green, lighter) */
.fi-icon-10 {
  background: rgba(57, 195, 75, 0.1);
}

/* ================================================================
   Bottom Links
   ================================================================ */
.bottom-links {
  margin: 0 32rpx 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.link-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid var(--border);
}
.link-item:last-child {
  border-bottom: none;
}
.lk-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.lk-icon {
  font-size: 36rpx;
}
.lk-text {
  font-size: 28rpx;
}
.lk-arrow {
  font-size: 28rpx;
  color: var(--muted);
}

/* ================================================================
   Profile Header
   ================================================================ */
.profile-header {
  background: var(--surface);
  padding: 48rpx 32rpx 40rpx;
  border-bottom: 2rpx solid var(--border);
}
.profile-top {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 24rpx;
}
.profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent-soft), rgba(85, 96, 207, 0.2));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 4rpx solid rgba(85, 96, 207, 0.15);
}
.profile-info {
  flex: 1;
}
.profile-name {
  font-family: var(--font-display);
  font-size: 36rpx;
  font-weight: 700;
}
.profile-level {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  margin-top: 8rpx;
  background: rgba(57, 195, 75, 0.1);
  color: var(--success);
  font-size: 24rpx;
  font-weight: 600;
}
.profile-settings {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* ================================================================
   Quick Stats (4-column grid)
   ================================================================ */
.quick-stats {
  margin: 0 32rpx 32rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.qs-item {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(20, 22, 29, 0.03);
}
.qs-val {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}
.qs-label {
  font-size: 20rpx;
  color: var(--muted);
  margin-top: 4rpx;
}
.qs-item:nth-child(1) .qs-val { color: var(--accent); }
.qs-item:nth-child(2) .qs-val { color: var(--success); }
.qs-item:nth-child(3) .qs-val { color: var(--success); }
.qs-item:nth-child(4) .qs-val { color: var(--warning); }

/* ================================================================
   Bottom Nav (fixed tab bar)
   ================================================================ */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: rgba(255, 255, 255, 0.92);
  border-top: 2rpx solid var(--border);
  display: flex;
  padding: 12rpx 0 env(safe-area-inset-bottom, 16rpx);
  z-index: 30;
  box-sizing: border-box;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 4rpx;
  color: var(--muted);
  font-size: 20rpx;
  transition: color 0.15s ease;
}
.nav-item .nav-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}
.nav-item.active {
  color: var(--accent);
}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.member-card::before { content: ''; position: absolute; top: -30px; right: -30px;
      width: 120px; height: 120px; border-radius: 50%;
      background: rgba(255,255,255,0.08); }
.member-card .mc-top { display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 12px; }
.member-card .mc-status { font-family: var(--font-display); font-size: 14px; font-weight: 600; }
.member-card .mc-badge { padding: 3px 10px; border-radius: 999px;
      background: rgba(255,255,255,0.2); font-size: 11px; font-weight: 600; }
.member-card .mc-countdown { font-family: var(--font-display); font-size: 28px; font-weight: 700; line-height: 1; }
.member-card .mc-countdown-label { font-size: 13px; opacity: 0.85; margin-top: 4px; }
.member-card .mc-expires { font-size: 12px; opacity: 0.7; margin-top: 8px; }
.qs-item .qs-val { font-family: var(--font-display); font-size: 17px; font-weight: 700; }
.qs-item .qs-label { font-size: 10px; color: var(--muted); margin-top: 2px; }
.func-item .fi-icon { width: 36px; height: 36px; border-radius: 10px; margin: 0 auto 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; }
.func-item .fi-label { font-size: 10px; font-weight: 500; line-height: 1.3; }
.func-item:nth-child(1) .fi-icon { background: var(--accent-soft); }
.func-item:nth-child(2) .fi-icon { background: var(--muted); }
.func-item:nth-child(3) .fi-icon { background: rgba(57, 195, 75, 0.1); }
.func-item:nth-child(4) .fi-icon { background: var(--muted); }
.func-item:nth-child(5) .fi-icon { background: var(--muted); }
.func-item:nth-child(6) .fi-icon { background: var(--muted); }
.func-item:nth-child(7) .fi-icon { background: var(--muted); }
.func-item:nth-child(8) .fi-icon { background: rgba(230, 173, 0, 0.1); }
.func-item:nth-child(9) .fi-icon { background: var(--muted); }
.func-item:nth-child(10) .fi-icon { background: var(--secondary-soft); }
.link-item .lk-left { display: flex; align-items: center; gap: 10px; }
.link-item .lk-left .lk-icon { font-size: 18px; }
.link-item .lk-arrow { color: var(--muted); font-size: 14px; }
