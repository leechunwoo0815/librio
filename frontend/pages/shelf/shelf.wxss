/* frontend/pages/shelf/shelf.wxss */

/* ============ Top Bar ============ */
.top-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  height: 112rpx;
  padding: 0 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
}
.top-bar .back-btn {
  background: none;
  border: none;
  font-size: 40rpx;
  color: var(--fg);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
}
.top-bar .top-bar-title {
  flex: 1;
  text-align: center;
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
}
.top-bar .back-btn:active { background: var(--accent-soft); }

/* ============ Tab Bar (Category Tabs) ============ */
.tab-bar {
  display: flex;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  padding: 0 32rpx;
}
.tab-bar .tab-btn {
  flex: 1;
  padding: 24rpx 0 20rpx;
  background: none;
  border: none;
  font-family: var(--font-body);
  font-size: 28rpx;
  font-weight: 500;
  color: var(--muted);
  position: relative;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tab-bar .tab-btn.active {
  color: var(--accent);
  font-weight: 600;
}
.tab-bar .tab-btn.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--accent);
  border-radius: 6rpx 6rpx 0 0;
}
.tab-bar .tab-count {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--muted);
  background: var(--accent-soft);
  border-radius: 20rpx;
  padding: 2rpx 12rpx;
  margin-left: 8rpx;
  vertical-align: middle;
}
.tab-bar .tab-btn.active .tab-count {
  color: var(--accent);
}

/* ============ Content Area ============ */
.content {
  padding: 32rpx;
}

/* ============ Tab Panel ============ */
.tab-panel {
  /* structural only */
}

/* ============ Stats bar ============ */
.stats-bar {
  display: flex;
  margin: 24rpx 32rpx 0;
  gap: 16rpx;
}

.s-item {
  flex: 1;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.s-val {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 700;
  color: var(--fg);
  line-height: 1.2;
}

.s-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

/* ============ Tabs (legacy alias) ============ */
.tabs {
  display: flex;
  padding: 0 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
}

.tab-btn {
  flex: 1;
  padding: 24rpx 0 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--muted);
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-btn.active {
  color: var(--accent);
  font-weight: 600;
}

.tab-btn.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--accent);
  border-radius: 6rpx 6rpx 0 0;
}

.tab-btn .tab-count {
  font-size: 22rpx;
  background: var(--accent-soft);
  border-radius: 20rpx;
  padding: 2rpx 12rpx;
  margin-left: 8rpx;
}

/* ============ Shelf count ============ */
.shelf-count {
  text-align: right;
  padding: 16rpx 32rpx 0;
}

.shelf-count-text {
  font-size: 24rpx;
  color: var(--muted);
}

/* ============ Book grid (2-column flexbox) ============ */
.book-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

/* ============ Book Card ============ */
.book-card {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(20, 22, 29, 0.06);
  display: flex;
  flex-direction: column;
  transition: transform 0.15s, box-shadow 0.15s;
  width: calc(50% - 12rpx);
}
.book-card:active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 2rpx rgba(20, 22, 29, 0.04);
}
.book-card .book-cover {
  width: 100%;
  height: 0;
  padding-bottom: 133.33%;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  margin-bottom: 20rpx;
  position: relative;
}
.book-card .book-cover.cover-1 { background: linear-gradient(135deg, #e8dff5 0%, #d4c5f9 100%); /* intentional decorative */ }
.book-card .book-cover.cover-2 { background: linear-gradient(135deg, #fce4ec 0%, #f8bbd0 100%); /* intentional decorative */ }
.book-card .book-cover.cover-3 { background: linear-gradient(135deg, #e0f2f1 0%, #b2dfdb 100%); /* intentional decorative */ }
.book-card .book-cover.cover-4 { background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%); /* intentional decorative */ }
.book-card .book-cover.cover-5 { background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%); /* intentional decorative */ }
.book-card .book-cover.cover-6 { background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%); /* intentional decorative */ }
.book-card .book-cover.cover-add {
  background: var(--bg);
  border: 4rpx dashed var(--border);
  font-size: 56rpx;
  color: var(--muted);
}
.book-card .book-cover-emoji {
  font-size: 88rpx;
}
.book-card .ar-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(20, 22, 29, 0.7);
  color: var(--surface);
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
.book-card .book-title {
  font-family: var(--font-display);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
  margin-bottom: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.book-card .book-author {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 16rpx;
}

/* ============ Expiry Info ============ */
.book-card .expiry-info {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.book-card .expiry-info.warning {
  color: var(--warning);
  font-weight: 500;
}
.book-card .expiry-info.urgent {
  color: var(--error);
  font-weight: 600;
}

/* ============ Progress Bar ============ */
.progress-wrap {
  margin-bottom: 20rpx;
}
.progress-wrap .progress-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
}
.progress-wrap .progress-label .progress-pct {
  font-weight: 600;
  color: var(--accent);
}
.progress-bar {
  height: 8rpx;
  background: var(--border);
  border-radius: 8rpx;
  overflow: hidden;
}
.progress-bar .progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

/* ============ Card Action Buttons ============ */
.card-btn {
  width: 100%;
  padding: 16rpx 0;
  border: none;
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 24rpx;
  font-weight: 600;
  transition: opacity 0.15s, transform 0.1s;
  line-height: 1.4;
}
.card-btn::after {
  border: none;
}
.card-btn:active { transform: scale(0.97); }
.card-btn.primary {
  background: var(--accent);
  color: var(--surface);
}
.card-btn.secondary {
  background: var(--accent-soft);
  color: var(--accent);
}
.card-btn.success {
  background: var(--success-soft);
  color: var(--success);
}

/* ============ Add Card ============ */
.add-card {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 440rpx;
  box-shadow: 0 2rpx 6rpx rgba(20, 22, 29, 0.06);
  border: 4rpx dashed var(--border);
  width: calc(50% - 12rpx);
}
.add-card:active { transform: scale(0.97); }
.add-card .add-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
}
.add-card .add-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--accent);
}
.add-card.disabled {
  opacity: 0.4;
  border-color: var(--border);
}
.add-card.disabled .add-icon { background: var(--border); }
.add-card.disabled .add-text { color: var(--muted); }

/* ============ Completed Info ============ */
.book-card .completed-info {
  margin-bottom: 16rpx;
}
.book-card .completed-info .finish-date {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
}
.book-card .completed-info .stats-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.book-card .completed-info .stat-badge {
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
.stat-badge.words {
  background: var(--accent-soft);
  color: var(--accent);
}
.stat-badge.quiz-pass {
  background: var(--success-soft);
  color: var(--success);
}
.stat-badge.quiz-fail {
  background: var(--warning-soft);
  color: var(--warning);
}
.book-card .checkmark {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--success);
  color: var(--surface);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

/* ============ Favorite Button ============ */
.book-card .fav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 22rpx;
  margin-top: 8rpx;
  color: var(--accent);
}

/* ============ Book Grid Item (legacy) ============ */
.book-grid-item {
  width: calc(50% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--surface);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(20, 22, 29, 0.06);
}

.book-grid-item:active {
  transform: scale(0.97);
}

.book-grid-cover {
  width: 100%;
  height: 0;
  padding-bottom: 133.33%;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.book-grid-emoji {
  font-size: 88rpx;
}

.book-grid-title {
  font-family: var(--font-display);
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 8rpx;
  margin-bottom: 4rpx;
  text-align: center;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  width: 100%;
  color: var(--fg);
}

.book-grid-progress {
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 600;
  font-family: var(--font-mono);
  margin-top: 4rpx;
  padding: 2rpx 12rpx;
  background: var(--accent-soft);
  border-radius: 999rpx;
}

.book-grid-mini-bar {
  width: 100%;
  height: 8rpx;
  background: var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  margin-top: 8rpx;
}

.book-grid-mini-bar .fill {
  height: 100%;
  border-radius: 8rpx;
}

/* ============ Add book slot (legacy) ============ */
.add-slot {
  width: calc(50% - 12rpx);
  min-height: 440rpx;
  border-radius: 24rpx;
  border: 4rpx dashed var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--muted);
  padding: 28rpx 24rpx 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(20, 22, 29, 0.06);
  background: var(--surface);
}

.add-slot.disabled {
  opacity: 0.4;
}

.add-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--accent);
  line-height: 1;
  margin-bottom: 16rpx;
}

.add-label {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 500;
}

/* ============ Shelf full hint ============ */
.shelf-full-hint {
  text-align: center;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: var(--warning);
  background: var(--warning-soft);
  margin: 0 32rpx 16rpx;
  border-radius: 24rpx;
}

/* ============ Book list (favorites & finished) ============ */
.book-list {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.book-row {
  display: flex;
  gap: 24rpx;
  background: var(--surface);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(20, 22, 29, 0.06);
}

.book-row-cover {
  width: 112rpx;
  height: 148rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.book-row-emoji {
  font-size: 88rpx;
}

.book-row-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.br-title {
  font-family: var(--font-display);
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  color: var(--fg);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.br-meta {
  font-size: 22rpx;
  color: var(--muted);
}

/* ============ Add to shelf button (favorites) ============ */
.add-shelf-btn {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: var(--accent);
  color: var(--surface);
  flex-shrink: 0;
  line-height: 1.4;
  border: none;
}

.add-shelf-btn:active {
  transform: scale(0.97);
}

.add-shelf-btn::after {
  border: none;
}

/* ============ Badges (finished tab) ============ */
.date-badge {
  font-size: 22rpx;
  color: var(--muted);
  padding: 4rpx 12rpx;
  background: var(--border);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.words-badge {
  font-size: 20rpx;
  color: var(--accent);
  font-weight: 600;
  font-family: var(--font-mono);
  margin-top: 4rpx;
  padding: 4rpx 12rpx;
  background: var(--accent-soft);
  border-radius: 12rpx;
}

/* ============ Empty state ============ */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-emoji {
  font-size: 112rpx;
  margin-bottom: 32rpx;
  line-height: 1.2;
}

.empty-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--fg);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--muted);
  line-height: 1.5;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: var(--accent);
  color: var(--surface);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 1.4;
}

.empty-btn::after {
  border: none;
}

.empty-btn:active {
  transform: scale(0.97);
}

/* ============ Bottom Tab Bar ============ */
.bottom-tabs {
  position: fixed;
    box-sizing: border-box;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: var(--surface);
  border-top: 2rpx solid var(--border);
  display: flex;
  padding: 12rpx 0 env(safe-area-inset-bottom, 16rpx);
  z-index: 200;
  box-sizing: border-box;
}
.bottom-tabs .tab-icon { font-size: 44rpx; }
.bottom-tabs .bottom-tab-label { font-size: 20rpx; }

/* ============ Toast ============ */
.toast {
  position: fixed;
    box-sizing: border-box;
  top: 140rpx;
  left: 50%;
  transform: translateX(-50%) translateY(-40rpx);
  background: rgba(20, 22, 29, 0.88);
  color: var(--surface);
  font-size: 26rpx;
  font-weight: 500;
  padding: 20rpx 40rpx;
  border-radius: 24rpx;
  z-index: 999;
  opacity: 1;
  pointer-events: none;
  white-space: nowrap;
  box-sizing: border-box;
}
.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ============ Section Header ============ */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-header .count {
  font-size: 26rpx;
  color: var(--muted);
}
.section-header .section-header-title {
  font-family: var(--font-display);
  font-size: 28rpx;
  font-weight: 600;
}

/* ============ Context Overlay Dialog ============ */
.ctx-overlay {
  position: fixed;
    box-sizing: border-box;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.2s ease;
  box-sizing: border-box;
}

.ctx-overlay.show {
  visibility: visible;
  opacity: 1;
}

.ctx-dialog {
  background: var(--surface);
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  width: calc(100% - 96rpx);
  max-width: 700rpx;
  text-align: center;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ctx-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  line-height: 1.2;
}

.ctx-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: var(--fg);
}

.ctx-sub {
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.ctx-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.ctx-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  border: none;
  text-align: center;
}

.ctx-btn::after {
  border: none;
}

.ctx-btn.cancel {
  background: var(--border);
  color: var(--muted);
}

.ctx-btn.confirm {
  background: var(--error);
  color: var(--surface);
}

