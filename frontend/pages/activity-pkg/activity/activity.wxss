/* frontend/pages/activity/activity.wxss */

/* ============ Top Bar ============ */
.top-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
  padding: 0 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
}
.top-bar .back-btn {
  position: absolute;
  left: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  font-size: 40rpx;
  color: var(--fg);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
}
.top-bar .back-btn:active { background: var(--accent-soft); }
.top-bar .title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
}
.top-bar .share-btn {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  font-size: 36rpx;
  color: var(--muted);
  padding: 8rpx 16rpx;
}

/* Nav Bar (legacy alias) */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
  padding: 0 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
}

.nav-bar .back-icon {
  font-size: 40rpx;
  color: var(--fg);
}

.nav-bar .title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
  color: var(--fg);
}

.share-btn {
  position: absolute;
  right: 32rpx;
  font-size: 36rpx;
  color: var(--muted);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
}

/* ============ Hero Section ============ */
.hero {
  height: 400rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--accent) 0%, #a78bfa 40%, #c4b5fd 70%, #ddd6fe 100%);
}
.hero::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}
.hero::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}
.hero .hero-emoji {
  font-size: 128rpx;
  z-index: 1;
}
.hero .hero-tag {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  color: var(--surface);
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  z-index: 1;
}
.hero .hero-status {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  background: var(--success);
  color: var(--surface);
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  z-index: 1;
}

/* ============ Info Card ============ */
.info-card {
  background: var(--surface);
  margin: -48rpx 32rpx 0;
  position: relative;
  z-index: 2;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(20, 22, 29, 0.08);
}
.info-card .activity-title {
  font-family: var(--font-display);
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 32rpx;
}
.info-card .info-rows {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ============ Info Row ============ */
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}
.info-row .info-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  width: 48rpx;
  text-align: center;
}
.info-row .info-content {
  flex: 1;
}
.info-row .info-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 4rpx;
}
.info-row .info-value {
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.4;
}
.info-row .info-value .highlight {
  color: var(--accent);
  font-weight: 600;
}

/* ============ Capacity Bar ============ */
.capacity-wrap {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid var(--border);
}
.capacity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.capacity-header .cap-label {
  font-size: 26rpx;
  font-weight: 500;
}
.capacity-header .cap-count {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
}
.capacity-bar {
  height: 16rpx;
  background: var(--border);
  border-radius: 16rpx;
  overflow: hidden;
}
.capacity-bar .cap-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), #a78bfa);
  border-radius: 16rpx;
  transition: width 0.8s ease;
}
.capacity-hint {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 12rpx;
}

/* ============ Price Row ============ */
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid var(--border);
}
.price-label {
  font-size: 24rpx;
  color: var(--muted);
}
.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--success);
}
.price-value .original {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--muted);
  text-decoration: line-through;
  margin-right: 12rpx;
}

/* ============ Section ============ */
.section {
  background: var(--surface);
  margin: 24rpx 32rpx 0;
  border-radius: var(--radius);
  padding: 32rpx 40rpx;
  box-shadow: 0 2rpx 6rpx rgba(20, 22, 29, 0.04);
}
.section-title {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.section-body {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--fg);
}
.section-body .highlight-list {
  list-style: none;
  padding: 0;
}
.section-body .highlight-list view {
  padding: 12rpx 0;
  padding-left: 40rpx;
  position: relative;
}

/* ============ Bring Box ============ */
.bring-box {
  background: var(--warning-soft);
  border-radius: var(--radius-sm);
  padding: 24rpx 28rpx;
}
.bring-box .bring-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--fg);
  margin-bottom: 12rpx;
}
.bring-box .bring-items {
  font-size: 24rpx;
  color: var(--fg);
  line-height: 1.7;
}

/* ============ QR Section ============ */
.qr-section {
  background: var(--surface);
  margin: 24rpx 32rpx 0;
  border-radius: var(--radius);
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 6rpx rgba(20, 22, 29, 0.04);
}
.qr-section .qr-title {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.qr-placeholder {
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto 24rpx;
  background: var(--bg);
  border-radius: var(--radius);
  border: 4rpx dashed var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--muted);
  gap: 16rpx;
}
.qr-placeholder .qr-icon {
  font-size: 80rpx;
}
.qr-hint {
  font-size: 22rpx;
  color: var(--muted);
  line-height: 1.5;
}

/* ============ FAQ Section ============ */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.faq-item {
  border-bottom: 2rpx solid var(--border);
  padding: 24rpx 0;
}
.faq-item:last-child {
  border-bottom: none;
}
.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
}
.faq-question .faq-arrow {
  font-size: 24rpx;
  color: var(--muted);
  transition: transform 0.2s ease;
}
.faq-item.open .faq-arrow {
  transform: rotate(90deg);
}
.faq-answer {
  font-size: 24rpx;
  color: var(--muted);
  line-height: 1.7;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
}
.faq-item.open .faq-answer {
  max-height: 400rpx;
  padding-top: 16rpx;
}

/* ============ Action Bar ============ */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--surface);
  border-top: 2rpx solid var(--border);
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom, 16rpx) + 24rpx);
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 200;
  box-sizing: border-box;
}
.action-bar .action-info {
  flex: 1;
}
.action-bar .action-price {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent);
}
.action-bar .action-price-label {
  font-size: 22rpx;
  color: var(--muted);
}
.action-bar .action-btn {
  flex-shrink: 0;
  padding: 24rpx 64rpx;
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}
.action-bar .action-btn.register {
  background: var(--accent);
  color: var(--surface);
  box-shadow: 0 8rpx 24rpx rgba(85, 96, 207, 0.3);
}
.action-bar .action-btn.registered {
  background: var(--success-soft);
  color: var(--success);
  box-shadow: none;
}
.action-bar .cancel-link {
  font-size: 24rpx;
  color: var(--muted);
  margin-left: 16rpx;
  white-space: nowrap;
}

/* ============ Teacher Card ============ */
.teacher-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 28rpx;
  background: var(--accent-soft);
  border-radius: var(--radius-sm);
}
.teacher-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #a78bfa);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}
.teacher-info {
  flex: 1;
}
.teacher-info .teacher-name {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}
.teacher-info .teacher-desc {
  font-size: 22rpx;
  color: var(--muted);
}

/* ============ Toast ============ */
.toast {
  position: fixed;
  top: 140rpx;
  left: 50%;
  transform: translateX(-50%) translateY(-40rpx);
  background: rgba(20, 22, 29, 0.88);
  color: var(--surface);
  font-size: 26rpx;
  font-weight: 500;
  padding: 20rpx 40rpx;
  border-radius: var(--radius);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s, transform 0.25s;
  white-space: nowrap;
}
.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ============ Section Divider ============ */
.section-divider {
  height: 2rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* ============ Tabs (list mode) ============ */
.tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 112rpx;
  z-index: 9;
}

.tab {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--muted);
  position: relative;
}

.tab.active {
  color: var(--accent);
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: var(--accent);
  border-radius: 2rpx;
}

/* ============ Activity List (list mode) ============ */
.activity-list {
  padding: 24rpx 32rpx;
}

.activity-card {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.activity-banner {
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-0 {
  background: linear-gradient(135deg, rgba(92, 77, 212, 0.12), rgba(107, 214, 107, 0.1));
}

.banner-1 {
  background: linear-gradient(135deg, rgba(75, 184, 75, 0.1), rgba(92, 77, 212, 0.08));
}

.banner-2 {
  background: linear-gradient(135deg, rgba(200, 130, 40, 0.12), rgba(92, 77, 212, 0.08));
}

.activity-banner-text {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
  text-align: center;
  padding: 32rpx;
}

.activity-body {
  padding: 28rpx 32rpx;
}

.activity-title {
  font-family: var(--font-display);
  font-size: 36rpx;
  font-weight: 700;
  color: var(--fg);
  line-height: 1.4;
  margin-bottom: 32rpx;
  display: block;
}

.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: var(--muted);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 28rpx;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.activity-status {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-open {
  background: var(--success-soft);
  color: var(--success);
}

.status-full {
  background: var(--error-soft);
  color: var(--error);
}

.status-past {
  background: rgba(122, 122, 140, 0.1);
  color: var(--muted);
}

.enroll-btn {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  background: var(--accent);
  font-size: 26rpx;
  font-weight: 600;
}

.enroll-btn text {
  color: var(--surface);
}

.enroll-btn.disabled {
  opacity: 0.4;
}

/* ============ Loading & Empty States ============ */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--muted);
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--muted);
}

/* ===== 原型缺失选择器补全 ===== */

.top-bar h1 { font-family: var(--font-display);
  font-size: 17px;
  font-weight: 600; }
.section-body p { margin-bottom: 8px; }
.section-body p:last-child { margin-bottom: 0; }
.section-body .highlight-list li { padding: 6px 0;
  padding-left: 20px;
  position: relative; }
.section-body .highlight-list li::before { content: '✨';
  position: absolute;
  left: 0;
  font-size: 12px; }
.action-bar .action-btn:active { transform: scale(0.97); }
