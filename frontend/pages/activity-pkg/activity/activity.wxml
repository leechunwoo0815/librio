<!-- frontend/pages/activity-pkg/activity/activity.wxml -->
<view class="page">
  <!-- Top Bar -->
  <view class="top-bar">
    <navigator class="back-btn" open-type="navigateBack" delta="1">
      <text>←</text>
    </navigator>
    <text class="title">活动中心</text>
    <view class="share-btn" bindtap="onShare">
      <text>⤴</text>
    </view>
  </view>

  <!-- Hero Section -->
  <view class="hero" wx:if="{{activityDetail}}">
    <text class="hero-tag">🔥 本周热门</text>
    <text class="hero-emoji">📚</text>
    <text class="hero-status">{{isRegistered ? '已报名' : '报名中'}}</text>
  </view>

  <!-- Info Card -->
  <view class="info-card" wx:if="{{activityDetail}}">
    <view class="activity-title">{{activityDetail.title}}</view>

    <view class="info-rows">
      <view class="info-row">
        <text class="info-icon">📅</text>
        <view class="info-content">
          <view class="info-label">活动时间</view>
          <view class="info-value">{{activityDetail.start_date}} - {{activityDetail.end_date}}</view>
        </view>
      </view>
      <view class="info-row">
        <text class="info-icon">📍</text>
        <view class="info-content">
          <view class="info-label">活动地点</view>
          <view class="info-value">{{activityDetail.location}}<text class="highlight" wx:if="{{activityDetail.address}}"> {{activityDetail.address}}</text></view>
        </view>
      </view>
      <view class="info-row" wx:if="{{activityDetail.teacher_name}}">
        <text class="info-icon">👩‍🏫</text>
        <view class="info-content">
          <view class="info-label">主讲老师</view>
          <view class="teacher-card">
            <view class="teacher-avatar">👩‍🏫</view>
            <view class="teacher-info">
              <view class="teacher-name">{{activityDetail.teacher_name}}</view>
              <view class="teacher-desc">{{activityDetail.teacher_desc}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Capacity -->
    <view class="capacity-wrap">
      <view class="capacity-header">
        <text class="cap-label">名额情况</text>
        <text class="cap-count">已报名 {{activityDetail.enrollment_count || 0}}/{{activityDetail.capacity || 0}}人</text>
      </view>
      <view class="capacity-bar">
        <view class="cap-fill" style="width: {{capacityPercent}}%"></view>
      </view>
      <view class="capacity-hint">剩余 {{remaining}} 个名额，建议尽快报名</view>
    </view>

    <!-- Price -->
    <view class="price-row">
      <text class="price-label">活动费用</text>
      <view class="price-value">
        <text class="original" wx:if="{{activityDetail.original_price}}">¥{{activityDetail.original_price}}</text>
        <text>{{activityDetail.price_text || '免费（会员专享）'}}</text>
      </view>
    </view>
  </view>

  <!-- Activity Description Section -->
  <view class="section" wx:if="{{activityDetail}}">
    <view class="section-title">📋 活动介绍</view>
    <view class="section-body">
      <text>{{activityDetail.description}}</text>
      <view class="highlight-list" wx:if="{{activityDetail.highlights && activityDetail.highlights.length > 0}}">
        <view wx:for="{{activityDetail.highlights}}" wx:key="index">
          <text>✨ {{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- What to Bring Section -->
  <view class="section" wx:if="{{activityDetail}}">
    <view class="section-title">🎒 参与须知</view>
    <view class="section-body">
      <view class="bring-box" wx:if="{{activityDetail.bring_items}}">
        <view class="bring-title">请携带：</view>
        <view class="bring-items">{{activityDetail.bring_items}}</view>
      </view>
    </view>
  </view>

  <!-- QR Code Section -->
  <view class="qr-section" wx:if="{{isRegistered}}">
    <view class="qr-title">📱 签到二维码</view>
    <view class="qr-placeholder">
      <text class="qr-icon">📋</text>
      <text>活动当天生成</text>
    </view>
    <view class="qr-hint">活动当天到达现场后，请出示此二维码签到</view>
  </view>

  <!-- FAQ Section -->
  <view class="section" wx:if="{{activityDetail && activityDetail.faqs && activityDetail.faqs.length > 0}}">
    <view class="section-title">❓ 常见问题</view>
    <view class="faq-list">
      <view class="faq-item {{item.open ? 'open' : ''}}" wx:for="{{activityDetail.faqs}}" wx:key="question" bindtap="toggleFaq" data-index="{{index}}">
        <view class="faq-question">
          <text>{{item.question}}</text>
          <text class="faq-arrow">›</text>
        </view>
        <view class="faq-answer">{{item.answer}}</view>
      </view>
    </view>
  </view>

  <!-- Tabs (list mode fallback) -->
  <view class="tabs" wx:if="{{!activityDetail}}">
    <view class="tab {{filterTab === 'upcoming' ? 'active' : ''}}" data-tab="upcoming" bindtap="onFilterChange">
      <text>即将举办</text>
    </view>
    <view class="tab {{filterTab === 'past' ? 'active' : ''}}" data-tab="past" bindtap="onFilterChange">
      <text>往期回顾</text>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- Upcoming List -->
  <view class="activity-list" wx:if="{{!loading && !activityDetail && filterTab === 'upcoming'}}">
    <view class="activity-card" wx:for="{{filteredActivities}}" wx:key="id"
      data-id="{{item.id}}" bindtap="onTapActivity">
      <view class="activity-banner banner-{{index % 3}}">
        <text class="activity-banner-text">{{item.bannerText || item.title}}</text>
      </view>
      <view class="activity-body">
        <text class="activity-title">{{item.title}}</text>
        <view class="activity-meta">
          <view class="meta-item" wx:if="{{item.start_date}}">
            <text class="meta-icon">📅</text>
            <text>{{item.start_date}} {{item.end_date}}</text>
          </view>
          <view class="meta-item" wx:if="{{item.location}}">
            <text class="meta-icon">📍</text>
            <text>{{item.location}}</text>
          </view>
          <view class="meta-item">
            <text class="meta-icon">👤</text>
            <text>已报名 {{item.enrollment_count || 0}} 人</text>
          </view>
        </view>
        <view class="activity-footer">
          <view class="activity-status {{item.statusClass}}">{{item.statusText}}</view>
          <view class="enroll-btn {{item.status !== 'registering' ? 'disabled' : ''}}"
                data-id="{{item.id}}" catchtap="onEnrollActivity">
            <text>{{item.status === 'registering' ? '立即报名' : item.statusText}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{filteredActivities.length === 0}}">
      <text class="empty-icon">🎉</text>
      <text class="empty-text">暂无即将举办的活动</text>
    </view>
  </view>

  <!-- Past List -->
  <view class="activity-list" wx:if="{{!loading && !activityDetail && filterTab === 'past'}}">
    <view class="activity-card" wx:for="{{filteredActivities}}" wx:key="id"
      data-id="{{item.id}}" bindtap="onTapActivity">
      <view class="activity-banner banner-2">
        <text class="activity-banner-text">{{item.bannerText || item.title}}</text>
      </view>
      <view class="activity-body">
        <text class="activity-title">{{item.title}}</text>
        <view class="activity-meta">
          <view class="meta-item" wx:if="{{item.start_date}}">
            <text class="meta-icon">📅</text>
            <text>{{item.start_date}} {{item.end_date}}</text>
          </view>
          <view class="meta-item" wx:if="{{item.location}}">
            <text class="meta-icon">📍</text>
            <text>{{item.location}}</text>
          </view>
        </view>
        <view class="activity-footer">
          <view class="activity-status status-past">已结束</view>
          <view class="enroll-btn disabled">
            <text>已结束</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{filteredActivities.length === 0}}">
      <text class="empty-icon">📅</text>
      <text class="empty-text">暂无往期活动</text>
    </view>
  </view>

  <!-- Bottom Action Bar -->
  <view class="action-bar" wx:if="{{activityDetail}}">
    <view class="action-info">
      <view class="action-price-label">会员专享</view>
      <view class="action-price">{{activityDetail.price_text || '免费'}}</view>
    </view>
    <view class="action-btn {{isRegistered ? 'registered' : 'register'}}" bindtap="onRegister">
      <text>{{isRegistered ? '已报名 ✓' : '立即报名'}}</text>
    </view>
    <text class="cancel-link" wx:if="{{isRegistered}}" bindtap="onCancel">取消报名</text>
  </view>

  <!-- Toast -->
  <view class="toast {{toastVisible ? 'show' : ''}}">
    <text>{{toastMsg}}</text>
  </view>
</view>
