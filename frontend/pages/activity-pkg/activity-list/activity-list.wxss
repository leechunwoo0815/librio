.top-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  height: 112rpx;
  padding: 0 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
}
.top-bar .back-btn {
  background: none;
  border: none;
  font-size: 40rpx;
  color: var(--fg);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
}
.top-bar .back-btn:active { background: var(--accent-soft); }
.top-bar .title {
  flex: 1;
  text-align: center;
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
}
.top-bar .share-btn {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 112rpx;
  z-index: 9;
}
.tab {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--muted);
  position: relative;
}
.tab.active {
  color: var(--accent);
  font-weight: 600;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: var(--accent);
  border-radius: 2rpx;
}

.activity-list {
  padding: 24rpx 32rpx;
}
.activity-card {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 24rpx;
}
.activity-banner {
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.banner-0 {
  background: linear-gradient(135deg, rgba(92, 77, 212, 0.12), rgba(107, 214, 107, 0.1));
}
.banner-1 {
  background: linear-gradient(135deg, rgba(75, 184, 75, 0.1), rgba(92, 77, 212, 0.08));
}
.banner-2 {
  background: linear-gradient(135deg, rgba(200, 130, 40, 0.12), rgba(92, 77, 212, 0.08));
}
.activity-banner-text {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
  text-align: center;
  padding: 32rpx;
}
.activity-body {
  padding: 28rpx 32rpx;
}
.activity-title {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 700;
  color: var(--fg);
  line-height: 1.4;
  margin-bottom: 24rpx;
  display: block;
}
.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: var(--muted);
}
.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.meta-icon {
  font-size: 28rpx;
}
.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.activity-status {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.status-open {
  background: var(--success-soft);
  color: var(--success);
}
.status-full {
  background: var(--error-soft);
  color: var(--error);
}
.status-past {
  background: rgba(122, 122, 140, 0.1);
  color: var(--muted);
}
.enroll-btn {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  background: var(--accent);
  font-size: 26rpx;
  font-weight: 600;
}
.enroll-btn text {
  color: var(--surface);
}
.enroll-btn.disabled {
  opacity: 0.4;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--muted);
  font-size: 28rpx;
}
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 28rpx;
  color: var(--muted);
}
