/* vocabulary.wxss — aligned with design/user-end/vocabulary.html */

/* Nav Bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.nav-bar .back-arrow {
  font-size: 40rpx;
}

.nav-bar .title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
}

.nav-bar .nav-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--muted);
}

.nav-bar .right-btn {
  margin-left: auto;
}

.nav-bar .right-btn .right-btn-text {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 500;
}

/* Stats Row */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 32rpx;
}

.stats-row .st {
  flex: 1;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
}

.st .st-val {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.st .st-label {
  font-size: 22rpx;
  color: var(--muted);
  display: block;
}

.st.learning .st-val {
  color: var(--accent);
}

.st.mastered .st-val {
  color: var(--success);
}

/* Tabs */
.tabs {
  display: flex;
  margin: 0 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  overflow: hidden;
}

.tab-btn {
  flex: 1;
  padding: 18rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--muted);
  text-align: center;
}

.tab-btn.active {
  background: var(--accent);
  color: var(--surface);
}

/* Sort Bar */
.sort-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
}

.sort-bar .count {
  font-size: 24rpx;
  color: var(--muted);
}

.sort-bar .sort-select {
  font-size: 24rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  background: var(--surface);
  color: var(--fg);
}

/* Word List */
.word-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.word-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
}

.word-item:active {
  transform: scale(0.98);
}

.word-main {
  flex: 1;
  min-width: 0;
}

.word-main .w-word {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.word-main .w-phonetic {
  font-size: 24rpx;
  color: var(--muted);
  display: block;
}

.word-main .w-def {
  font-size: 26rpx;
  color: var(--fg);
  margin-top: 4rpx;
  display: block;
}

.word-tag {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
  white-space: nowrap;
}

.word-tag.learning {
  background: var(--accent-soft);
  color: var(--accent);
}

.word-tag.mastered {
  background: var(--success-soft);
  color: var(--success);
}

.word-actions {
  display: flex;
  gap: 8rpx;
}

.word-actions .action-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: var(--muted);
}

.word-actions .action-btn .action-icon {
  font-size: 32rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--muted);
}

.empty-state .emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 28rpx;
}

.empty-state .text-sub {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 24rpx;
}

/* Loading */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: var(--muted);
}

/* Flashcard Overlay */
.flashcard-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  visibility: hidden;
  opacity: 0;
}

.flashcard-overlay.show {
  visibility: visible;
  opacity: 1;
}

.flashcard {
  width: 600rpx;
  height: 760rpx;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 24rpx;
  box-shadow: 0 32rpx 96rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.flashcard .fc-word {
  font-family: var(--font-display);
  font-size: 64rpx;
  font-weight: 700;
}

.flashcard .fc-phonetic {
  font-size: 32rpx;
  color: var(--muted);
}

.flashcard .fc-def {
  font-size: 36rpx;
  color: var(--fg);
}

.flashcard .fc-hint {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 16rpx;
}

.fc-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.fc-btn {
  padding: 20rpx 40rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.fc-btn.again {
  background: var(--accent-soft);
  color: var(--accent);
}

.fc-btn.got {
  background: var(--success);
  color: var(--surface);
}

.fc-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fc-close .fc-close-icon {
  font-size: 32rpx;
  color: var(--surface);
}

/* Review Progress Bar */
.review-progress-bar {
  position: absolute;
  top: 80rpx;
  left: 48rpx;
  right: 48rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 31;
}

.review-progress-track {
  flex: 1;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
}

.review-progress-fill {
  height: 100%;
  background: var(--surface);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.review-progress-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  white-space: nowrap;
  font-weight: 600;
}

/* Review Complete Overlay */
.review-complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--success-soft), rgba(57, 195, 75, 0.75));
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  visibility: hidden;
  opacity: 0;
}

.review-complete-overlay.show {
  visibility: visible;
  opacity: 1;
  animation: completeFadeIn 0.3s ease;
}

@keyframes completeFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.review-complete-card {
  width: 560rpx;
  background: var(--surface);
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.2);
  animation: completeScaleIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes completeScaleIn {
  0% {
    transform: scale(0.3);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.review-complete-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.review-complete-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--fg);
  display: block;
  margin-bottom: 12rpx;
}

.review-complete-desc {
  font-size: 28rpx;
  color: var(--muted);
  display: block;
  margin-bottom: 48rpx;
}

.review-complete-btn {
  width: 360rpx;
  margin: 0 auto;
  background: var(--success);
  color: var(--surface);
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 88rpx;
  height: 88rpx;
  padding: 0;
}

/* 排序选择器 - 字体 */
.sort-bar .sort-select {
  font-family: var(--font-body);
}

/* 选项 active 态 */
.action-btn:active {
  background: var(--accent-soft);
  color: var(--accent);
}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-bar .back svg { width: 20px; height: 20px; }
.sort-bar select { font-size: 12px; border: 1px solid var(--border); border-radius: 6px; padding: 4px 8px; background: var(--surface); color: var(--fg); }
.word-actions button { width: 30px; height: 30px; display: grid; place-items: center; border-radius: 8px; color: var(--muted); }
.word-actions button:hover { background: var(--accent-soft); color: var(--accent); }
.word-actions button svg { width: 16px; height: 16px; }
