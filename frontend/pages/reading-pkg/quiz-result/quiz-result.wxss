/* frontend/pages/quiz-result/quiz-result.wxss */

.result-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  background: var(--bg);
  position: relative;
}

/* Confetti */
.confetti-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 99;
  overflow: hidden;
}

.confetti-piece {
  position: absolute;
  border-radius: 4rpx;
  top: -40rpx;
  animation: confettiFall 2.5s ease-in forwards;
}

@keyframes confettiFall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(720deg);
    opacity: 0;
  }
}

/* Result Card */
.result-card {
  width: 100%;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  padding: 64rpx 48rpx;
  text-align: center;
  position: relative;
}

/* Icons */
.result-icon {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: popIn 0.4s ease;
}

@keyframes popIn {
  0% { transform: scale(0); }
  70% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.result-icon-pass {
  background: rgba(57, 195, 75, 0.1);
}

.result-icon-fail {
  background: rgba(230, 173, 0, 0.1);
}

.icon-check {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--success);
}

.icon-warning {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--warning);
}

/* Badge */
.result-badge {
  display: inline-block;
  padding: 8rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.badge-pass {
  background: rgba(57, 195, 75, 0.1);
  color: var(--success);
}

.badge-fail {
  background: rgba(230, 173, 0, 0.1);
  color: var(--warning);
}

/* Score Circle */
.score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.score-ring {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  border: 16rpx solid var(--border);
  position: absolute;
  top: 0;
  left: 0;
}

.ring-pass {
  border-color: var(--success);
}

.ring-fail {
  border-color: var(--warning);
}

.score-inner {
  display: flex;
  align-items: baseline;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.score-value {
  font-family: var(--font-display);
  font-size: 72rpx;
  font-weight: 700;
  color: var(--fg);
  line-height: 1;
}

.score-text {
  font-family: var(--font-display);
  font-size: 72rpx;
  font-weight: 700;
  position: relative;
  z-index: 1;
}

.score-unit {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--muted);
  margin-left: 4rpx;
}

/* Result Title */
.result-title {
  font-family: var(--font-display);
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.title-pass {
  color: var(--success);
}

.title-fail {
  color: var(--warning);
}

.result-sub {
  font-size: 28rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
}

/* Stats Row */
.stats-row {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin: 32rpx 0;
  padding: 24rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-val {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: var(--muted);
}

/* Auto Actions */
.auto-actions {
  text-align: left;
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: var(--radius-sm);
  background: rgba(57, 195, 75, 0.1);
  border: 2rpx solid rgba(57, 195, 75, 0.2);
}

.aa-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--success);
  margin-bottom: 12rpx;
}

.aa-item {
  font-size: 24rpx;
  color: var(--fg);
  padding: 4rpx 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.aa-check {
  color: var(--success);
  font-weight: 700;
  font-size: 28rpx;
}

.check {
  color: var(--success);
  font-weight: 700;
}

/* Wrong Questions Review */
.wrong-review {
  text-align: left;
  margin-top: 32rpx;
  padding: 28rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
}

.wrong-review h4 {
  font-family: var(--font-display);
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--warning);
}

.wrong-item {
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.wrong-item:last-child {
  border-bottom: none;
}

.wrong-q {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.wrong-a {
  font-size: 24rpx;
  color: var(--muted);
}

.wrong-a .correct {
  color: var(--success);
  font-weight: 600;
}

/* Level Up Banner */
.level-up-banner {
  margin-top: 32rpx;
  padding: 32rpx;
  border-radius: var(--radius);
  background: linear-gradient(135deg, rgba(85, 96, 207, 0.12), rgba(57, 195, 75, 0.08));
  border: 2rpx solid rgba(85, 96, 207, 0.15);
  text-align: center;
  animation: shimmer 2s ease infinite;
}

@keyframes shimmer {
  0%, 100% { box-shadow: 0 0 0 0 rgba(85, 96, 207, 0); }
  50% { box-shadow: 0 0 40rpx 8rpx rgba(85, 96, 207, 0.15); }
}

.lu-emoji {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.lu-text {
  font-family: var(--font-display);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--accent);
}

.lu-sub {
  font-size: 26rpx;
  color: var(--muted);
  margin-top: 8rpx;
}

/* Promotion Celebration Card */
.promo-card {
  margin-top: 32rpx;
  padding: 40rpx;
  border-radius: var(--radius);
  background: linear-gradient(135deg, rgba(85, 96, 207, 0.12), rgba(57, 195, 75, 0.08));
  border: 2rpx solid rgba(85, 96, 207, 0.15);
  text-align: center;
  animation: shimmer 2s ease infinite;
}

.promo-card .promo-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.promo-card .promo-title {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 8rpx;
}

.promo-card .promo-sub {
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 24rpx;
}

.promo-card .promo-link {
  display: inline-block;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--surface);
  font-size: 26rpx;
  font-weight: 600;
}

/* Button Group */
.btn-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 48rpx;
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  border-radius: var(--radius);
  background: var(--accent);
  color: var(--surface);
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  width: 100%;
  padding: 28rpx;
  border-radius: var(--radius);
  background: var(--surface);
  border: 2rpx solid var(--border);
  color: var(--fg);
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-sizing: border-box;
}

/* Level Up Celebration Overlay */
.level-up-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(85, 96, 207, 0.85), rgba(230, 173, 0, 0.75));
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: overlayFadeIn 0.3s ease;
}

@keyframes overlayFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.level-up-card {
  width: 580rpx;
  background: var(--surface);
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.25);
  animation: scaleIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes scaleIn {
  0% {
    transform: scale(0.3);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.level-up-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
  animation: emojiPop 0.6s ease 0.2s both;
}

@keyframes emojiPop {
  0% { transform: scale(0) rotate(-20deg); }
  60% { transform: scale(1.2) rotate(5deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.level-up-title {
  font-family: var(--font-display);
  font-size: 48rpx;
  font-weight: 700;
  color: var(--fg);
  display: block;
  margin-bottom: 16rpx;
}

.level-up-desc {
  font-size: 30rpx;
  color: var(--muted);
  display: block;
  margin-bottom: 48rpx;
}

.level-up-card .btn-primary {
  width: 400rpx;
  margin: 0 auto;
  background: var(--accent);
  color: var(--surface);
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 88rpx;
  height: 88rpx;
  padding: 0;
}

/* 鼓励文案 */
.encourage-box {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(230, 173, 0, 0.1);
  border-radius: var(--radius);
  font-size: 28rpx;
  color: var(--warning);
  text-align: center;
}

/* 错题回顾 */
.wrong-review-section {
  width: 100%;
  margin-top: 24rpx;
}
.wrong-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--accent);
}
.toggle-arrow {
  font-size: 24rpx;
  color: var(--muted);
}
.wrong-list {
  margin-top: 16rpx;
}
.wrong-list-item {
  background: var(--surface);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid var(--error);
}
.wrong-q-num {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
}
.wrong-q-text {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.wrong-answers {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}
.wrong-user-answer {
  font-size: 24rpx;
  color: var(--error);
}
.wrong-correct-answer {
  font-size: 24rpx;
  color: var(--success);
  font-weight: 600;
}
.wrong-explanation {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 2rpx solid var(--border);
}
.explain-label {
  font-weight: 600;
  color: var(--fg);
}

/* 通过结果图标 */
.result-icon-pass svg {
  width: 88rpx;
  height: 88rpx;
  color: var(--success);
}

/* 失败结果图标 */
.result-icon-fail svg {
  width: 88rpx;
  height: 88rpx;
  color: var(--warning);
}

/* 通过徽章 */
.badge-pass {
  background: var(--success-soft);
  color: var(--success);
}

/* 失败徽章 */
.badge-fail {
  background: var(--warning-soft);
  color: var(--warning);
}

/* 通过结果标题 */
.result-title-pass {
  color: var(--success);
}

/* 失败结果标题 */
.result-title-fail {
  color: var(--warning);
}

/* 提交按钮活跃态 */
.btn-primary:active {
  opacity: 0.85;
}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.result-icon-pass .celebration { position: absolute; font-size: 24px;
      animation: floatUp 0.8s ease forwards; }
@keyframes floatUp { 0% 
      50% 
      100% }
.result-badge.pass { background: var(--success-soft); color: var(--success); }
.result-badge.fail { background: var(--warning-soft); color: var(--warning); }
.score-circle svg { position: absolute; width: 120px; height: 120px; transform: rotate(-90deg); }
.score-circle .score-text { position: relative; z-index: 1;
      font-family: var(--font-display); font-size: 36px; font-weight: 700; }
.score-circle .score-unit { font-size: 16px; font-weight: 400; }
.result-title.pass { color: var(--success); }
.result-title.fail { color: var(--warning); }
.stat-item .stat-val { font-family: var(--font-display); font-size: 20px; font-weight: 700; color: var(--accent); }
.stat-item .stat-label { font-size: 11px; color: var(--muted); }
.level-up-banner .lu-emoji { font-size: 32px; margin-bottom: 8px; }
.level-up-banner .lu-text { font-family: var(--font-display); font-size: 16px; font-weight: 600; color: var(--accent); }
.level-up-banner .lu-sub { font-size: 13px; color: var(--muted); margin-top: 4px; }
.auto-actions .aa-title { font-size: 13px; font-weight: 600; color: var(--success);
      margin-bottom: 6px; }
.auto-actions .aa-item { font-size: 12px; color: var(--fg); padding: 2px 0;
      display: flex; align-items: center; gap: 6px; }
.auto-actions .aa-item .check { color: var(--success); font-weight: 700; }
