/* frontend/pages/book-detail/book-detail.wxss */

.page-bg {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  color: var(--muted);
  font-size: 28rpx;
}

/* Nav bar */
.nav-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.nav-bar .title {
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 600;
}

/* Hero cover (prototype alias) */
.hero-cover {
  width: 220rpx;
  height: 296rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--accent-soft), rgba(85,96,207,0.12));
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.audio-badge-lg {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: var(--accent-soft);
  color: var(--accent);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  z-index: 2;
}

/* Hero info (prototype alias) */
.hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-title {
  font-family: var(--font-display);
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.hero-author {
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 20rpx;
}

.hero-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.hero-tags .tag {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* Book hero */
.book-hero {
  display: flex;
  gap: 32rpx;
  padding: 40rpx 32rpx;
  background: var(--surface);
  margin-bottom: 20rpx;
}

.book-cover-lg {
  width: 220rpx;
  height: 296rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--accent-soft), rgba(85,96,207,0.12));
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.book-cover-bar {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 600;
}

.book-cover-lg .book-cover-letter {
  position: relative;
  z-index: 1;
  font-family: var(--font-display);
  font-size: 112rpx;
}

.book-hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.book-hero-title {
  font-family: var(--font-display);
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.book-hero-author {
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 20rpx;
}

.book-hero-publisher {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 20rpx;
}

.book-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.book-tags .tag {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-ar {
  background: var(--accent-soft);
  color: var(--accent);
}

.tag-words {
  background: rgba(85, 95, 105, 0.1);
  color: var(--muted);
}

.tag-time {
  background: rgba(57, 195, 75, 0.1);
  color: var(--success);
}

.tag-age {
  background: var(--success-soft);
  color: var(--success);
}

.tag-series {
  background: var(--warning-soft);
  color: var(--warning);
}

.quiz-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: var(--warning-soft);
  color: var(--warning);
  font-size: 22rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

/* Inventory status bar */
.inv-bar {
  margin: 0 32rpx 20rpx;
  padding: 20rpx 28rpx;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.inv-bar.in-stock {
  background: rgba(57, 195, 75, 0.1);
  color: var(--success);
}

.inv-bar.out-of-stock {
  background: rgba(85, 95, 105, 0.08);
  color: var(--muted);
}

.inv-bar .inv-detail {
  margin-left: auto;
  font-family: var(--font-display);
  font-weight: 700;
}

/* Reading progress */
.reading-progress {
  margin: 0 32rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx 32rpx;
}

.reading-progress .rp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.reading-progress .rp-title {
  font-family: var(--font-display);
  font-size: 28rpx;
  font-weight: 600;
}

.reading-progress .rp-pct {
  font-family: var(--font-display);
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 600;
}

.rp-bar {
  height: 12rpx;
  background: var(--border);
  border-radius: 6rpx;
  overflow: hidden;
}

.rp-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 6rpx;
}

/* Audio info */
.audio-info {
  margin: 0 32rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.audio-info .ai-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.audio-info .ai-text {
  flex: 1;
}

.audio-info .ai-title {
  font-size: 28rpx;
  font-weight: 500;
}

.audio-info .ai-meta {
  font-size: 24rpx;
  color: var(--muted);
}

.audio-info .ai-btn {
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--surface);
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

/* Inventory */
.inventory {
  margin: 0 32rpx 24rpx;
  display: flex;
  gap: 16rpx;
}

.inv-card {
  flex: 1;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx;
  text-align: center;
}

.inv-card .inv-num {
  font-family: var(--font-display);
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.inv-card .inv-label {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 8rpx;
}

.inv-total .inv-num {
  color: var(--fg);
}

.inv-avail .inv-num {
  color: var(--success);
}

/* Section cards */
.section-card {
  margin: 0 32rpx 20rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(20, 22, 29, 0.04);
}

.section-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  width: 36rpx;
  height: 36rpx;
}

.section-card-title {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
}

.desc-text {
  font-size: 26rpx;
  color: var(--fg);
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.desc-text.expanded {
  -webkit-line-clamp: unset;
}

.expand-btn {
  color: var(--accent);
  font-size: 26rpx;
  font-weight: 500;
  margin-top: 12rpx;
}

/* Book info grid */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  font-weight: 600;
}

/* Table of contents */
.toc-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
  font-size: 26rpx;
}

.toc-item:last-child {
  border-bottom: none;
}

.toc-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toc-num {
  font-family: var(--font-mono);
  color: var(--accent);
  font-weight: 600;
}

.toc-arrow {
  color: var(--muted);
  font-size: 32rpx;
}

/* Related books */
.related-scroll {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 8rpx;
}

.related-scroll::-webkit-scrollbar {
  display: none;
}

.related-card {
  flex-shrink: 0;
  width: 200rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.related-card .rc-cover {
  width: 100%;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  background: linear-gradient(135deg, var(--accent-soft), rgba(85,96,207,0.12));
}

.related-card .rc-body {
  padding: 12rpx 16rpx;
}

.related-card .rc-title {
  font-size: 22rpx;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.related-card .rc-ar {
  font-size: 20rpx;
  color: var(--accent);
  font-weight: 600;
  margin-top: 4rpx;
}

/* Bottom action bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  border-top: 2rpx solid var(--border);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  z-index: 20;
  box-sizing: border-box;
}

.action-btn {
  padding: 26rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.action-btn:active {
  transform: scale(0.97);
}

.action-primary {
  flex: 1;
  background: var(--accent);
  color: var(--surface);
  box-shadow: 0 8rpx 32rpx rgba(85, 96, 207, 0.3);
}

.action-secondary {
  flex: 1;
  background: var(--warning);
  color: var(--surface);
  box-shadow: 0 8rpx 32rpx rgba(230, 173, 0, 0.3);
}

.action-fav {
  flex: 0.6;
  background: var(--surface);
  color: var(--muted);
  border: 2rpx solid var(--border);
}

.fav-active {
  background: var(--accent-soft);
  color: var(--accent);
  border-color: rgba(85, 96, 207, 0.2);
}

/* ================================================================
   Standalone Progress Section (not wrapped in .reading-progress)
   ================================================================ */
.progress-section {
  margin: 0 32rpx 20rpx;
}

.progress-section .rp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-section .rp-title {
  font-family: var(--font-display);
  font-size: 28rpx;
  font-weight: 600;
}

.progress-section .rp-pct {
  font-family: var(--font-display);
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 600;
}

.progress-section .rp-bar {
  height: 12rpx;
  background: var(--border);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-section .rp-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 6rpx;
}

/* ================================================================
   Section Card h3 with icon (prototype layout)
   ================================================================ */
.section-card h3 {
  font-family: var(--font-display);
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-card h3 .icon {
  font-size: 32rpx;
}

/* ================================================================
   Info item (empty container for grid children)
   ================================================================ */
.info-item {
  /* grid child container */
}

/* ================================================================
   Tag color refinements
   ================================================================ */
.tag-time {
  background: rgba(57, 195, 75, 0.1);
  color: var(--success);
}

.inv-bar.in-stock {
  background: rgba(57, 195, 75, 0.1);
  color: var(--success);
}

/* ================================================================
   Action button aliases (prototype naming)
   ================================================================ */
.btn-primary {
  flex: 1;
  background: var(--accent);
  color: var(--surface);
  box-shadow: 0 8rpx 32rpx rgba(85, 96, 207, 0.3);
}

.btn-secondary {
  flex: 1;
  background: var(--warning);
  color: var(--surface);
  box-shadow: 0 8rpx 32rpx rgba(230, 173, 0, 0.3);
}

.btn-outline {
  flex: 0.6;
  background: var(--surface);
  color: var(--muted);
  border: 2rpx solid var(--border);
}

/* ================================================================
   State Toggle (prototype demo control)
   ================================================================ */
.state-toggle {
  margin: 0 32rpx 20rpx;
  padding: 20rpx 28rpx;
  background: var(--bg);
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  color: var(--muted);
  text-align: center;
}

.state-toggle button {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: var(--border);
  color: var(--muted);
  margin: 0 4rpx;
  transition: all 0.12s;
}

.state-toggle button.active {
  background: var(--accent);
  color: var(--surface);
}

/* ===== 原型缺失选择器补全 ===== */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-bar .back svg { width: 20px; height: 20px; }
.hero-cover .audio-badge-lg { position: absolute; top: 8px; right: 8px;
      background: var(--accent-soft); color: var(--accent);
      padding: 3px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; }
.rp-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.rp-title { font-family: var(--font-display); font-size: 14px; font-weight: 600; }
.rp-pct { font-family: var(--font-display); font-size: 13px; color: var(--accent); font-weight: 600; }
